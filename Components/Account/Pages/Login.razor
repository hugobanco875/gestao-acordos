@page "/Account/Login"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using GestaoAcordos.Data

@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Login> Logger
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject UserManager<ApplicationUser> UserManager
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject GestaoAcordos.Services.AdministradorService AdministradorSvc

<PageTitle>Entrar</PageTitle>

<div class="login-heading">
    <span>Acesso à plataforma</span>
    <h1>Bem-vindo de volta</h1>
    <p>Entre com suas credenciais para continuar.</p>
</div>

<StatusMessage Message="@errorMessage" />

<EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login" class="login-form">
    <DataAnnotationsValidator />
    <ValidationSummary class="text-danger login-validation" role="alert" />

    <div class="login-field">
        <label for="Input.Email">E-mail</label>
        <div class="login-input">
            <i class="bi bi-envelope"></i>
            <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
        </div>
        <ValidationMessage For="() => Input.Email" class="text-danger" />
    </div>

    <div class="login-field">
        <div class="login-label-row">
            <label for="Input.Password">Senha</label>
            <a href="Account/ForgotPassword">Esqueci minha senha</a>
        </div>
        <div class="login-input">
            <i class="bi bi-lock"></i>
            <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Digite sua senha" />
        </div>
        <ValidationMessage For="() => Input.Password" class="text-danger" />
    </div>

    <label class="login-remember">
        <InputCheckbox @bind-Value="Input.RememberMe" class="form-check-input" />
        <span>Manter conectado neste dispositivo</span>
    </label>

    <button type="submit" class="btn btn-primary login-submit">
        Entrar <i class="bi bi-arrow-right"></i>
    </button>

    @if (_semUsuarios)
    {
        <p class="login-register">Primeiro acesso? <a href="Account/Register">Configurar administrador inicial</a></p>
    }
</EditForm>

<style>
.login-heading>span{display:block;color:var(--cor-primaria);font-size:.7rem;font-weight:800;letter-spacing:.11em;text-transform:uppercase}.login-heading h1{margin:.55rem 0 .45rem;color:#172033;font-size:1.85rem;letter-spacing:-.035em;border:0!important;outline:0!important;box-shadow:none!important}.login-heading p{margin:0 0 1.8rem;color:#7b8494;font-size:.88rem;line-height:1.6}.login-form{display:grid;gap:1.15rem}.login-field{display:grid;gap:.48rem}.login-field label,.login-label-row label{color:#344054;font-size:.77rem;font-weight:700}.login-label-row{display:flex;justify-content:space-between;align-items:center}.login-label-row a,.login-register a{color:var(--cor-primaria);font-size:.74rem;font-weight:700;text-decoration:none}.login-input{position:relative}.login-input>i{position:absolute;left:14px;top:50%;z-index:2;transform:translateY(-50%);color:#98a1b2}.login-input .form-control{height:49px;padding-left:2.65rem;border-color:#dfe3ea;border-radius:13px;background:#fff;font-size:.9rem}.login-input .form-control:focus{border-color:color-mix(in srgb,var(--cor-primaria) 65%,#dfe3ea);box-shadow:0 0 0 4px color-mix(in srgb,var(--cor-primaria) 10%,transparent)}.login-remember{display:flex;align-items:center;gap:.55rem;color:#667085;font-size:.77rem;cursor:pointer}.login-submit{width:100%;min-height:50px;margin-top:.15rem;border:0;border-radius:13px;font-weight:750;box-shadow:0 12px 28px color-mix(in srgb,var(--cor-primaria) 22%,transparent)}.login-submit i{margin-left:.4rem}.login-register{margin:.25rem 0 0;text-align:center;color:#8a93a3;font-size:.76rem}.login-validation{margin:0;padding-left:1rem;font-size:.78rem}
</style>

@code {
    private string? errorMessage;
    private bool _semUsuarios;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (HttpMethods.IsGet(HttpContext.Request.Method))
        {
            await HttpContext.SignOutAsync(IdentityConstants.ExternalScheme);
        }

        _semUsuarios = !await AdministradorSvc.ExisteUsuarioAsync();
    }

    public async Task LoginUser()
    {
        var usuario = await UserManager.FindByEmailAsync(Input.Email);
        if (usuario is not null && !usuario.Ativo)
        {
            errorMessage = "Seu acesso está inativo. Procure um administrador do sistema.";
            return;
        }

        var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);
        if (result.Succeeded)
        {
            Logger.LogInformation("Usuário entrou no sistema.");
            if (usuario is not null)
            {
                await using var db = await DbFactory.CreateDbContextAsync();
                var atual = await db.Users.FindAsync(usuario.Id);
                if (atual is not null) atual.UltimoAcessoEm = DateTime.Now;
                await db.SaveChangesAsync();
            }
            RedirectManager.RedirectTo(ReturnUrl);
        }
        else if (result.IsLockedOut)
        {
            RedirectManager.RedirectTo("Account/Lockout");
        }
        else
        {
            errorMessage = "E-mail ou senha inválidos.";
        }
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Informe o e-mail.")]
        [EmailAddress(ErrorMessage = "E-mail inválido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Informe a senha.")]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}
