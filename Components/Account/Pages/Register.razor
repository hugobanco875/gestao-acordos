@page "/Account/Register"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using GestaoAcordos.Data
@using GestaoAcordos.Services

@inject UserManager<ApplicationUser> UserManager
@inject IUserStore<ApplicationUser> UserStore
@inject SignInManager<ApplicationUser> SignInManager
@inject ILogger<Register> Logger
@inject AdministradorService AdministradorSvc
@inject IdentityRedirectManager RedirectManager

<PageTitle>@(_primeiroUsuario ? "Configurar primeiro acesso" : "Novo usuário")</PageTitle>

<div class="user-create-page">
    <div class="user-create-shell">
        <div class="user-create-header">
            <div class="user-create-icon" aria-hidden="true">
                <i class="bi bi-person-plus-fill"></i>
            </div>
            <div>
                <span class="user-create-eyebrow">@(_primeiroUsuario ? "Primeiro acesso" : "Administração")</span>
                <h1>@(_primeiroUsuario ? "Configurar administrador inicial" : "Criar novo usuário")</h1>
                <p>@(_primeiroUsuario
                    ? "Cadastre a primeira conta responsável pela administração do sistema."
                    : "Adicione uma nova pessoa e defina se ela terá acesso administrativo.")</p>
            </div>
        </div>

        <div class="user-create-card">
            @if (_primeiroUsuario)
            {
                <div class="alert alert-info d-flex gap-2 align-items-start" role="alert">
                    <i class="bi bi-info-circle-fill mt-1"></i>
                    <div>Este é o primeiro acesso. A conta criada será o administrador inicial do sistema.</div>
                </div>
            }

            <StatusMessage Message="@Message" />

            <EditForm Model="Input" method="post" OnValidSubmit="RegisterUser" FormName="register">
                <DataAnnotationsValidator />
                <ValidationSummary class="text-danger validation-summary" role="alert" />

                <div class="form-section">
                    <div class="form-section-title">
                        <i class="bi bi-person-vcard"></i>
                        <span>Dados de acesso</span>
                    </div>

                    <div class="form-grid">
                        <div class="form-floating form-grid-full">
                            <InputText @bind-Value="Input.Email" id="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="nome@exemplo.com" />
                            <label for="Input.Email">E-mail</label>
                            <ValidationMessage For="() => Input.Email" class="text-danger field-validation" />
                        </div>

                        <div class="form-floating">
                            <InputText type="password" @bind-Value="Input.Password" id="Input.Password" class="form-control" autocomplete="new-password" aria-required="true" placeholder="senha" />
                            <label for="Input.Password">Senha</label>
                            <ValidationMessage For="() => Input.Password" class="text-danger field-validation" />
                        </div>

                        <div class="form-floating">
                            <InputText type="password" @bind-Value="Input.ConfirmPassword" id="Input.ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true" placeholder="repita a senha" />
                            <label for="Input.ConfirmPassword">Confirmar senha</label>
                            <ValidationMessage For="() => Input.ConfirmPassword" class="text-danger field-validation" />
                        </div>
                    </div>
                </div>

                @if (!_primeiroUsuario)
                {
                    <div class="permission-card">
                        <div class="form-check form-switch m-0">
                            <InputCheckbox @bind-Value="Input.Administrador" id="Input.Administrador" class="form-check-input" role="switch" />
                            <label class="form-check-label" for="Input.Administrador">
                                <strong>Usuário administrador</strong>
                                <span>Permite gerenciar usuários, configurações, gerar backups e restaurar dados.</span>
                            </label>
                        </div>
                    </div>
                }

                <div class="user-create-actions">
                    <a class="btn btn-outline-secondary" href="@(_primeiroUsuario ? "Account/Login" : "usuarios")">
                        <i class="bi bi-arrow-left"></i>
                        <span>@(_primeiroUsuario ? "Voltar ao login" : "Cancelar")</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-lg"></i>
                        <span>@(_primeiroUsuario ? "Criar administrador inicial" : "Criar usuário")</span>
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private IEnumerable<IdentityError>? identityErrors;
    private bool _primeiroUsuario;

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private string? Message => identityErrors is null
        ? null
        : $"Erro: {string.Join(", ", identityErrors.Select(error => error.Description))}";

    protected override async Task OnInitializedAsync()
    {
        _primeiroUsuario = !await AdministradorSvc.ExisteUsuarioAsync();

        if (!_primeiroUsuario && !await AdministradorSvc.EhAdministradorAtivoAsync(HttpContext.User))
        {
            RedirectManager.RedirectTo("Account/AccessDenied");
        }
    }

    public async Task RegisterUser(EditContext editContext)
    {
        // Revalida no servidor para impedir cadastro por acesso direto ou corrida entre requisições.
        var primeiroUsuarioAgora = !await AdministradorSvc.ExisteUsuarioAsync();
        var administradorCriador = primeiroUsuarioAgora
            ? null
            : await AdministradorSvc.ObterAdministradorAtivoAsync(HttpContext.User);

        if (!primeiroUsuarioAgora && administradorCriador is null)
        {
            RedirectManager.RedirectTo("Account/AccessDenied");
        }

        var user = CreateUser();
        user.Ativo = true;
        user.Administrador = primeiroUsuarioAgora || Input.Administrador;
        user.SolicitouAdministrador = false;
        user.CriadoEm = DateTime.Now;
        user.AdministradorAutorizadorId = !primeiroUsuarioAgora && user.Administrador
            ? administradorCriador!.Id
            : null;
        user.AdministradorAutorizadoEm = !primeiroUsuarioAgora && user.Administrador
            ? DateTime.Now
            : null;

        await UserStore.SetUserNameAsync(user, Input.Email, CancellationToken.None);
        var emailStore = GetEmailStore();
        await emailStore.SetEmailAsync(user, Input.Email, CancellationToken.None);
        var result = await UserManager.CreateAsync(user, Input.Password);

        if (!result.Succeeded)
        {
            identityErrors = result.Errors;
            return;
        }

        Logger.LogInformation("Nova conta criada com senha.");

        if (primeiroUsuarioAgora)
        {
            await SignInManager.SignInAsync(user, isPersistent: false);
            RedirectManager.RedirectTo(ReturnUrl);
        }

        RedirectManager.RedirectTo("usuarios");
    }

    private ApplicationUser CreateUser()
    {
        try
        {
            return Activator.CreateInstance<ApplicationUser>();
        }
        catch
        {
            throw new InvalidOperationException($"Não foi possível criar uma instância de '{nameof(ApplicationUser)}'.");
        }
    }

    private IUserEmailStore<ApplicationUser> GetEmailStore()
    {
        if (!UserManager.SupportsUserEmail)
        {
            throw new NotSupportedException("O store de usuários precisa dar suporte a e-mail.");
        }

        return (IUserEmailStore<ApplicationUser>)UserStore;
    }

    private sealed class InputModel
    {
        [Required(ErrorMessage = "Informe o e-mail.")]
        [EmailAddress(ErrorMessage = "E-mail inválido.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Informe a senha.")]
        [StringLength(100, ErrorMessage = "A senha deve ter entre {2} e {1} caracteres.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "As senhas não coincidem.")]
        public string ConfirmPassword { get; set; } = "";

        public bool Administrador { get; set; }
    }
}
