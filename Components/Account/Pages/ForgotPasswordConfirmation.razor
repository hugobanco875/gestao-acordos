@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Redefinir senha</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5 text-center">
        <h1 class="h3 mb-3">Link de redefinição</h1>
        @if (!string.IsNullOrEmpty(Code))
        {
            <p>Clique no botão abaixo para definir uma nova senha:</p>
            <a class="btn btn-primary btn-lg" href="@resetUrl">
                <i class="bi bi-key"></i> Redefinir minha senha
            </a>
        }
        else
        {
            <div class="alert alert-warning">Não foi possível gerar o link.</div>
            <a href="Account/ForgotPassword">Tentar novamente</a>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery] private string? Code { get; set; }
    [SupplyParameterFromQuery] private string? Email { get; set; }

    private string resetUrl = "";

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(Code))
        {
            resetUrl = $"Account/ResetPassword?code={Uri.EscapeDataString(Code)}";
            if (!string.IsNullOrEmpty(Email))
            {
                resetUrl += $"&email={Uri.EscapeDataString(Email)}";
            }
        }
    }
}
