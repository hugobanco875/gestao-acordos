@implements IDisposable
@inject NavigationManager NavigationManager

<div class="brand-row">
    <a class="brand" href="" data-enhance-nav="false">
        <span class="brand-mark">
            @if (!string.IsNullOrWhiteSpace(Config?.LogoDataUrl))
            {
                <img src="@Config.LogoDataUrl" alt="Logomarca da empresa" />
            }
            else
            {
                <i class="bi bi-briefcase-fill"></i>
            }
        </span>
        <span><strong>@(Config?.NomeSistema ?? "Gestão de Acordos")</strong><small>@(string.IsNullOrWhiteSpace(Config?.SubtituloSistema) ? "Advocacia especializada" : Config.SubtituloSistema)</small></span>
    </a>
    <label class="menu-toggle" title="Abrir menu"><input type="checkbox" class="navbar-toggler" /><i class="bi bi-list"></i></label>
</div>

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler')?.click()">
    <nav class="nav flex-column" data-enhance-nav="false">
        <AuthorizeView>
            <Authorized>
                <div class="nav-caption">Visão geral</div>
                <div class="nav-item"><NavLink class="nav-link" href="" Match="NavLinkMatch.All"><i class="bi bi-grid-1x2"></i><span>Dashboard</span></NavLink></div>
                <div class="nav-caption">Operação</div>
                <div class="nav-item"><NavLink class="nav-link" href="empresas"><i class="bi bi-buildings"></i><span>Empresas</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="clientes"><i class="bi bi-people"></i><span>Clientes</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="parcelas"><i class="bi bi-wallet2"></i><span>Baixa de Parcelas</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="eventos"><i class="bi bi-calendar3"></i><span>Eventos</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="relatorios"><i class="bi bi-bar-chart"></i><span>Relatórios</span></NavLink></div>
                <div class="nav-caption">Administração</div>
                <div class="nav-item"><NavLink class="nav-link" href="usuarios"><i class="bi bi-person-badge"></i><span>Usuários</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="backup"><i class="bi bi-cloud-arrow-down"></i><span>Backup</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="configuracoes"><i class="bi bi-sliders"></i><span>Configurações</span></NavLink></div>
                <div class="nav-spacer"></div>
                <div class="nav-item"><NavLink class="nav-link" href="Account/Manage"><i class="bi bi-person-gear"></i><span>Minha conta</span></NavLink></div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item"><NavLink class="nav-link" href="Account/Login"><i class="bi bi-box-arrow-in-right"></i><span>Entrar</span></NavLink></div>
                <div class="nav-item"><NavLink class="nav-link" href="Account/Register"><i class="bi bi-person-plus"></i><span>Criar conta</span></NavLink></div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [Parameter] public Configuracao? Config { get; set; }
    private string? currentUrl;
    protected override void OnInitialized() { currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri); NavigationManager.LocationChanged += OnLocationChanged; }
    private void OnLocationChanged(object? sender, LocationChangedEventArgs e) { currentUrl = NavigationManager.ToBaseRelativePath(e.Location); StateHasChanged(); }
    public void Dispose() => NavigationManager.LocationChanged -= OnLocationChanged;
}
