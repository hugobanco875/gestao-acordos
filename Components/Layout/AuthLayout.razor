@inherits LayoutComponentBase
@inject GestaoAcordos.Services.ConfiguracaoService ConfigSvc
@inject IJSRuntime JS

<HeadContent>
    <style>
        :root {
            --cor-primaria: @cfg.CorPrimaria;
            --cor-menu: @cfg.CorMenu;
        }
    </style>
</HeadContent>

<div class="auth-shell">
    <aside class="auth-aside" aria-label="Apresentação do sistema">
        <a class="auth-brand" href="">
            <span class="auth-brand-mark">
                @if (!string.IsNullOrWhiteSpace(cfg.LogoDataUrl))
                {
                    <img src="@cfg.LogoDataUrl" alt="Logomarca da empresa" />
                }
                else
                {
                    <i class="bi bi-briefcase-fill"></i>
                }
            </span>
            <span class="auth-brand-copy">
                <strong>@NomeSistema</strong>
                <small>@SubtituloSistema</small>
            </span>
        </a>

        <div class="auth-message">
            <span class="auth-kicker">CONTROLE, ORGANIZAÇÃO E CLAREZA</span>
            <h1>Administre seus acordos com tranquilidade.</h1>
            <p>Acompanhe clientes, parcelas, recebimentos e compromissos em uma experiência simples e segura.</p>
        </div>

        <div class="auth-benefits">
            <div><i class="bi bi-check2"></i><span>Visão clara dos vencimentos</span></div>
            <div><i class="bi bi-check2"></i><span>Acesso pelo computador ou celular</span></div>
            <div><i class="bi bi-check2"></i><span>Dados protegidos e organizados</span></div>
        </div>

        <small class="auth-copyright">© @GestaoAcordos.Services.RelogioSistema.Agora.Year @NomeSistema</small>
    </aside>

    <main class="auth-content">
        <div class="auth-mobile-brand">
            <span class="auth-brand-mark">
                @if (!string.IsNullOrWhiteSpace(cfg.LogoDataUrl))
                {
                    <img src="@cfg.LogoDataUrl" alt="Logomarca da empresa" />
                }
                else
                {
                    <i class="bi bi-briefcase-fill"></i>
                }
            </span>
            <strong>@NomeSistema</strong>
        </div>

        <div class="auth-card">
            <div class="auth-security"><span></span> Ambiente seguro</div>
            @Body
        </div>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>Ocorreu um erro inesperado. <a href="." class="reload">Recarregar</a><span class="dismiss">×</span></div>

@code {
    private Configuracao cfg = new();
    private string NomeSistema => string.IsNullOrWhiteSpace(cfg.NomeSistema) ? "Gestão de Acordos" : cfg.NomeSistema;
    private string SubtituloSistema => string.IsNullOrWhiteSpace(cfg.SubtituloSistema) ? "Advocacia especializada" : cfg.SubtituloSistema;

    protected override async Task OnInitializedAsync()
    {
        try { cfg = await ConfigSvc.ObterAsync(); }
        catch { cfg = new Configuracao(); }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await JS.InvokeVoidAsync("themeManager.initialize", cfg.Tema);
    }
}
