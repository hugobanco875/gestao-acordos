@inherits LayoutComponentBase
@inject GestaoAcordos.Services.ConfiguracaoService ConfigSvc

<HeadContent>
    <style>
        :root {
            --cor-primaria: @cfg.CorPrimaria;
            --cor-menu: @cfg.CorMenu;
        }
        .sidebar {
            background-image: none !important;
            background-color: var(--cor-menu) !important;
        }
        .btn-primary {
            --bs-btn-bg: var(--cor-primaria);
            --bs-btn-border-color: var(--cor-primaria);
            --bs-btn-hover-bg: var(--cor-primaria);
            --bs-btn-hover-border-color: var(--cor-primaria);
            --bs-btn-active-bg: var(--cor-primaria);
            --bs-btn-active-border-color: var(--cor-primaria);
            --bs-btn-disabled-bg: var(--cor-primaria);
            --bs-btn-disabled-border-color: var(--cor-primaria);
        }
        .btn-outline-primary {
            --bs-btn-color: var(--cor-primaria);
            --bs-btn-border-color: var(--cor-primaria);
            --bs-btn-hover-bg: var(--cor-primaria);
            --bs-btn-hover-border-color: var(--cor-primaria);
            --bs-btn-active-bg: var(--cor-primaria);
            --bs-btn-active-border-color: var(--cor-primaria);
        }
        .text-primary { color: var(--cor-primaria) !important; }
        .bg-primary { background-color: var(--cor-primaria) !important; }
        .badge.bg-primary { background-color: var(--cor-primaria) !important; }
        .content a:not(.btn) { color: var(--cor-primaria); }
    </style>
</HeadContent>

<div class="page">
    <div class="sidebar">
        <NavMenu Config="cfg" />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3 text-muted d-none d-sm-inline">
                        <i class="bi bi-person-circle"></i> @context.User.Identity?.Name
                    </span>
                    <form action="Account/Logout" method="post">
                        <AntiforgeryToken />
                        <button type="submit" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-box-arrow-right"></i> Sair
                        </button>
                    </form>
                </Authorized>
                <NotAuthorized>
                    <a href="Account/Login" class="btn btn-sm btn-primary">Entrar</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ocorreu um erro inesperado.
    <a href="." class="reload">Recarregar</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private Configuracao cfg = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            cfg = await ConfigSvc.ObterAsync();
        }
        catch
        {
            cfg = new Configuracao();
        }
    }
}
