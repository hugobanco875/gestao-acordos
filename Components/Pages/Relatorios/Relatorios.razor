@page "/relatorios"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject RelatorioService Relatorio
@inject IJSRuntime JS

<PageTitle>Relatórios</PageTitle>

<h1 class="h3 mb-3"><i class="bi bi-file-earmark-bar-graph"></i> Relatório Financeiro</h1>

<div class="card mb-3">
    <div class="card-body">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">Situação</label>
                <select class="form-select form-select-sm" @bind="situacao">
                    <option value="todas">Todas</option>
                    <option value="baixadas">Baixadas (pagas)</option>
                    <option value="aberto">Em aberto</option>
                    <option value="vencidas">Vencidas</option>
                    <option value="avencer">A vencer</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Tipo</label>
                <select class="form-select form-select-sm" @bind="tipo">
                    <option value="todos">Entradas e parcelas</option>
                    <option value="entradas">Somente entradas</option>
                    <option value="parcelas">Somente parcelas</option>
                </select>
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small mb-1">De</label>
                <InputDate class="form-control form-control-sm" @bind-Value="de" />
            </div>
            <div class="col-6 col-md-2">
                <label class="form-label small mb-1">Até</label>
                <InputDate class="form-control form-control-sm" @bind-Value="ate" />
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Empresa</label>
                <select class="form-select form-select-sm" @onchange="OnEmpresaChanged">
                    <option value="0">Todas</option>
                    @foreach (var e in empresas)
                    {
                        <option value="@e.Id" selected="@(e.Id == empresaId)">@e.Nome</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small mb-1">Cliente</label>
                <select class="form-select form-select-sm" @bind="clienteId">
                    <option value="0">Todos</option>
                    @foreach (var c in clientes.Where(c => empresaId == 0 || c.ClienteEmpresas.Any(ce => ce.EmpresaId == empresaId)))
                    {
                        <option value="@c.Id">@c.Nome</option>
                    }
                </select>
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-2 gap-3 flex-wrap">
            <div>
                <div class="form-check form-switch mb-1">
                    <input class="form-check-input" type="checkbox" role="switch" id="limitarAbertos" @bind="limitarAbertosAoPeriodo" />
                    <label class="form-check-label small" for="limitarAbertos">Limitar títulos em aberto ao período informado</label>
                </div>
                <small class="text-muted">@DescricaoPeriodo</small>
            </div>
            <button class="btn btn-primary btn-sm" @onclick="Gerar"><i class="bi bi-funnel"></i> Gerar</button>
        </div>
    </div>
</div>

@if (itens is not null)
{
    <div class="d-flex justify-content-between align-items-center flex-wrap mb-2 gap-2">
        <div>
            <span class="me-3">@itens.Count movimentação(ões)</span>
            <span class="me-3">Recebido: <strong class="text-success">@itens.Where(i => i.Paga).Sum(i => i.ValorPago ?? i.Valor).ToString("C")</strong></span>
            <span class="me-3">Em aberto: <strong class="text-danger">@itens.Where(i => !i.Paga).Sum(i => i.Valor).ToString("C")</strong></span>
            <span>Vencido: <strong class="text-warning">@itens.Where(i => !i.Paga && i.Vencimento < hoje).Sum(i => i.Valor).ToString("C")</strong></span>
        </div>
        <div>
            <button class="btn btn-outline-success btn-sm" @onclick="ExportarExcel" disabled="@(itens.Count == 0)"><i class="bi bi-file-earmark-excel"></i> Excel</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="ExportarPdf" disabled="@(itens.Count == 0)"><i class="bi bi-file-earmark-pdf"></i> PDF</button>
        </div>
    </div>

    @if (itens.Count == 0)
    {
        <div class="alert alert-info">Nenhuma movimentação para o período/filtros selecionados.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>Empresa</th>
                        <th>Cliente</th>
                        <th class="d-none d-md-table-cell">Processo</th>
                        <th>Movimento</th>
                        <th>Data</th>
                        <th>Situação</th>
                        <th>Pagamento</th>
                        <th>Forma</th>
                        <th class="text-end">Valor</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var i in itens)
                    {
                        <tr>
                            <td>@i.Empresa</td>
                            <td>@i.Cliente</td>
                            <td class="d-none d-md-table-cell">@i.NumeroProcesso</td>
                            <td>@i.Movimento</td>
                            <td>@i.Vencimento.ToString("dd/MM/yyyy")</td>
                            <td>
                                @if (i.Paga)
                                {
                                    <span class="badge bg-success">Paga</span>
                                }
                                else if (i.Vencimento < hoje)
                                {
                                    <span class="badge bg-danger">Vencida</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Em aberto</span>
                                }
                            </td>
                            <td>@i.DataPagamento?.ToString("dd/MM/yyyy")</td>
                            <td>@i.FormaPagamento</td>
                            <td class="text-end">@((i.ValorPago ?? i.Valor).ToString("C"))</td>
                        </tr>
                    }
                </tbody>
                <tfoot>
                    <tr>
                        <th colspan="8" class="text-end">TOTAL</th>
                        <th class="text-end">@itens.Sum(i => i.ValorPago ?? i.Valor).ToString("C")</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    }
}

@code {
    private List<Empresa> empresas = new();
    private List<Cliente> clientes = new();
    private List<RelatorioParcelaItem>? itens;

    private string situacao = "todas";
    private string tipo = "todos";
    private DateOnly de = new(GestaoAcordos.Services.RelogioSistema.Agora.Year, GestaoAcordos.Services.RelogioSistema.Agora.Month, 1);
    private DateOnly ate = GestaoAcordos.Services.RelogioSistema.Hoje;
    private int empresaId;
    private int clienteId;
    private bool limitarAbertosAoPeriodo;

    private readonly DateOnly hoje = GestaoAcordos.Services.RelogioSistema.Hoje;

    protected override async Task OnInitializedAsync()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        empresas = await db.Empresas.OrderBy(e => e.Nome).ToListAsync();
        clientes = await db.Clientes.Include(c => c.ClienteEmpresas).OrderBy(c => c.Nome).ToListAsync();
        await Gerar();
    }

    private void OnEmpresaChanged(ChangeEventArgs e)
    {
        empresaId = int.TryParse(e.Value?.ToString(), out var v) ? v : 0;
        clienteId = 0;
    }

    private async Task Gerar()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var q = db.Parcelas
            .Include(p => p.Acordo)!.ThenInclude(a => a!.Cliente)
            .Include(p => p.Acordo)!.ThenInclude(a => a!.Empresa)
            .AsQueryable();

        if (empresaId > 0)
            q = q.Where(p => p.Acordo!.EmpresaId == empresaId);
        if (clienteId > 0)
            q = q.Where(p => p.Acordo!.ClienteId == clienteId);

        // Regra financeira consolidada:
        // - recebidos usam a data de pagamento;
        // - títulos abertos aparecem independentemente do período por padrão;
        // - quando o usuário ativa a opção de limitar abertos, usa-se o vencimento.
        // Isso evita o cenário em que "Todas" mostra apenas entradas/recebimentos porque
        // as próximas parcelas vencem depois da data final selecionada.
        q = situacao switch
        {
            "baixadas" => q.Where(p => p.Paga && p.DataPagamento.HasValue
                && p.DataPagamento.Value >= de && p.DataPagamento.Value <= ate),

            "aberto" => limitarAbertosAoPeriodo
                ? q.Where(p => !p.Paga && p.DataVencimento >= de && p.DataVencimento <= ate)
                : q.Where(p => !p.Paga),

            "vencidas" => limitarAbertosAoPeriodo
                ? q.Where(p => !p.Paga && p.DataVencimento < hoje
                    && p.DataVencimento >= de && p.DataVencimento <= ate)
                : q.Where(p => !p.Paga && p.DataVencimento < hoje),

            "avencer" => limitarAbertosAoPeriodo
                ? q.Where(p => !p.Paga && p.DataVencimento >= hoje
                    && p.DataVencimento >= de && p.DataVencimento <= ate)
                : q.Where(p => !p.Paga && p.DataVencimento >= hoje),

            _ => limitarAbertosAoPeriodo
                ? q.Where(p =>
                    (p.Paga && p.DataPagamento.HasValue
                        && p.DataPagamento.Value >= de && p.DataPagamento.Value <= ate)
                    || (!p.Paga && p.DataVencimento >= de && p.DataVencimento <= ate))
                : q.Where(p =>
                    (p.Paga && p.DataPagamento.HasValue
                        && p.DataPagamento.Value >= de && p.DataPagamento.Value <= ate)
                    || !p.Paga)
        };

        q = tipo switch
        {
            "entradas" => q.Where(p => p.Tipo == TipoMovimentoFinanceiro.Entrada),
            "parcelas" => q.Where(p => p.Tipo == TipoMovimentoFinanceiro.Parcela),
            _ => q
        };

        var parcelas = await q
            .OrderBy(p => p.Acordo!.Empresa!.Nome)
            .ThenBy(p => p.Acordo!.Cliente!.Nome)
            .ThenBy(p => p.DataVencimento)
            .ThenBy(p => p.Numero)
            .ToListAsync();

        itens = parcelas.Select(p => new RelatorioParcelaItem(
            p.Acordo!.Empresa!.Nome,
            p.Acordo!.Cliente!.Nome,
            p.Acordo!.NumeroProcesso,
            p.Tipo == TipoMovimentoFinanceiro.Entrada ? "Entrada" : $"Parcela {p.Numero:000}",
            NomeForma(p.FormaPagamento),
            p.Valor,
            p.DataVencimento,
            p.DataPagamento,
            p.ValorPago,
            p.Paga)).ToList();
    }

    private static string NomeForma(FormaPagamento f) => FormasPagamento.Nome(f);

    private string FiltroDescricao()
    {
        var sit = situacao switch
        {
            "baixadas" => "Baixadas (pagas)",
            "aberto" => "Em aberto",
            "vencidas" => "Vencidas",
            "avencer" => "A vencer",
            _ => "Todas"
        };
        var emp = empresaId == 0 ? "Todas as empresas" : $"Empresa: {empresas.FirstOrDefault(e => e.Id == empresaId)?.Nome}";
        var tip = tipo switch { "entradas" => "Somente entradas", "parcelas" => "Somente parcelas", _ => "Entradas e parcelas" };
        var cli = clienteId == 0 ? "Todos os clientes" : $"Cliente: {clientes.FirstOrDefault(c => c.Id == clienteId)?.Nome}";
        var escopoAbertos = limitarAbertosAoPeriodo ? "Abertos limitados ao período" : "Todos os títulos em aberto";
        return $"Situação: {sit}  |  Tipo: {tip}  |  {emp}  |  {cli}  |  {escopoAbertos}";
    }

    private string DescricaoPeriodo => situacao switch
    {
        "baixadas" => "O período é aplicado à data de pagamento.",
        "aberto" or "vencidas" or "avencer" => limitarAbertosAoPeriodo
            ? "O período é aplicado ao vencimento dos títulos em aberto."
            : "Todos os títulos em aberto são exibidos, independentemente do vencimento.",
        _ => limitarAbertosAoPeriodo
            ? "Pagos usam a data de pagamento; abertos usam a data de vencimento."
            : "Pagos usam a data de pagamento; todos os títulos em aberto são incluídos."
    };

    private async Task ExportarExcel()
    {
        if (itens is null) return;
        var bytes = Relatorio.GerarExcel(itens, de, ate, FiltroDescricao());
        await JS.InvokeVoidAsync("appDownload.fromBytes",
            $"relatorio_financeiro_{de:yyyyMMdd}_{ate:yyyyMMdd}.xlsx",
            "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
            Convert.ToBase64String(bytes));
    }

    private async Task ExportarPdf()
    {
        if (itens is null) return;
        var bytes = Relatorio.GerarPdf(itens, de, ate, FiltroDescricao());
        await JS.InvokeVoidAsync("appDownload.fromBytes",
            $"relatorio_financeiro_{de:yyyyMMdd}_{ate:yyyyMMdd}.pdf",
            "application/pdf",
            Convert.ToBase64String(bytes));
    }
}
