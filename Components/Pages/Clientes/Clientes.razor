@page "/clientes"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject EnderecoService Endereco
@inject IJSRuntime JS

<PageTitle>Clientes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-people"></i> Clientes</h1>
    <button class="btn btn-primary" @onclick="Novo" disabled="@(empresas is null || empresas.Count == 0)">
        <i class="bi bi-plus-lg"></i> Novo cliente
    </button>
</div>

@if (empresas is not null && empresas.Count == 0)
{
    <div class="alert alert-warning">
        Cadastre uma <a href="empresas">empresa</a> antes de cadastrar clientes.
    </div>
}

<div class="mb-3">
    <input class="form-control" placeholder="Buscar por nome..." @bind="busca" @bind:event="oninput" />
</div>

@if (clientes is null)
{
    <p><em>Carregando...</em></p>
}
else
{
    var filtrados = clientes
        .Where(c => string.IsNullOrWhiteSpace(busca) || c.Nome.Contains(busca, StringComparison.OrdinalIgnoreCase))
        .ToList();

    @if (filtrados.Count == 0)
    {
        <div class="alert alert-info">Nenhum cliente encontrado.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Nome</th>
                        <th class="d-none d-md-table-cell">Empresas</th>
                        <th class="d-none d-md-table-cell">Telefone</th>
                        <th class="text-center">Acordos</th>
                        <th class="text-end">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in filtrados)
                    {
                        <tr>
                            <td>@c.Nome</td>
                            <td class="d-none d-md-table-cell">@NomesEmpresas(c)</td>
                            <td class="d-none d-md-table-cell">@c.Telefone</td>
                            <td class="text-center">@c.Acordos.Count</td>
                            <td class="text-end text-nowrap">
                                <a class="btn btn-sm btn-outline-success" href="clientes/@c.Id" title="Acordos"><i class="bi bi-folder2-open"></i></a>
                                <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(c)" title="Editar"><i class="bi bi-pencil"></i></button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Excluir(c)" title="Excluir"><i class="bi bi-trash"></i></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@if (editando)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <EditForm Model="modelo" OnValidSubmit="Salvar">
                    <DataAnnotationsValidator />
                    <div class="modal-header">
                        <h5 class="modal-title">@(modelo.Id == 0 ? "Novo cliente" : "Editar cliente")</h5>
                        <button type="button" class="btn-close" @onclick="Cancelar"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Empresas *</label>
                            <div class="border rounded-3 p-2 empresa-multi-list">
                                @foreach (var e in empresas!)
                                {
                                    <div class="form-check py-1">
                                        <input class="form-check-input" type="checkbox" id="empresa-@e.Id"
                                               checked="@empresasSelecionadas.Contains(e.Id)"
                                               @onchange="args => AlternarEmpresa(e.Id, args.Value)" />
                                        <label class="form-check-label" for="empresa-@e.Id">@e.Nome</label>
                                    </div>
                                }
                            </div>
                            <div class="form-text">Selecione uma ou mais empresas às quais este cliente pertence.</div>
                            @if (!string.IsNullOrEmpty(empresaMsg))
                            {
                                <div class="text-danger small mt-1">@empresaMsg</div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Nome *</label>
                            <InputText class="form-control" @bind-Value="modelo.Nome" />
                            <ValidationMessage For="() => modelo.Nome" />
                        </div>
                        <div class="row g-2">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">CPF/CNPJ</label>
                                <InputText class="form-control" @bind-Value="modelo.CpfCnpj" placeholder="000.000.000-00 ou 00.000.000/0000-00" data-mask="cpf-cnpj" inputmode="numeric" maxlength="18" autocomplete="off" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Telefone</label>
                                <InputText class="form-control" @bind-Value="modelo.Telefone" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">E-mail</label>
                            <InputText class="form-control" @bind-Value="modelo.Email" />
                            <ValidationMessage For="() => modelo.Email" />
                        </div>

                        <hr />
                        <div class="row g-2">
                            <div class="col-md-4 mb-3">
                                <label class="form-label">CEP</label>
                                <div class="input-group">
                                    <InputText class="form-control" @bind-Value="modelo.Cep" placeholder="00000-000" data-mask="cep" inputmode="numeric" maxlength="9" autocomplete="postal-code" />
                                    <button type="button" class="btn btn-outline-secondary" @onclick="BuscarCep" disabled="@buscandoCep" title="Buscar endereço pelo CEP">
                                        @if (buscandoCep)
                                        {
                                            <span class="spinner-border spinner-border-sm"></span>
                                        }
                                        else
                                        {
                                            <i class="bi bi-search"></i>
                                        }
                                    </button>
                                </div>
                            </div>
                            <div class="col-md-8 mb-3">
                                <label class="form-label">Endereço</label>
                                <InputText class="form-control" @bind-Value="modelo.Logradouro" />
                            </div>
                        </div>
                        @if (cepMsg is not null)
                        {
                            <div class="text-danger small mb-2">@cepMsg</div>
                        }
                        <div class="row g-2">
                            <div class="col-md-3 mb-3">
                                <label class="form-label">Número</label>
                                <InputText class="form-control" @bind-Value="modelo.Numero" />
                            </div>
                            <div class="col-md-5 mb-3">
                                <label class="form-label">Complemento</label>
                                <InputText class="form-control" @bind-Value="modelo.Complemento" />
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Bairro</label>
                                <InputText class="form-control" @bind-Value="modelo.Bairro" />
                            </div>
                        </div>
                        <div class="row g-2">
                            <div class="col-md-9 mb-3">
                                <label class="form-label">Cidade</label>
                                <InputText class="form-control" @bind-Value="modelo.Cidade" />
                            </div>
                            <div class="col-md-3 mb-3">
                                <label class="form-label">UF</label>
                                <InputText class="form-control" @bind-Value="modelo.Uf" maxlength="2" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Observações</label>
                            <InputTextArea class="form-control" rows="2" @bind-Value="modelo.Observacoes" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Salvar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private List<Cliente>? clientes;
    private List<Empresa>? empresas;
    private bool editando;
    private Cliente modelo = new();
    private string busca = "";
    private bool buscandoCep;
    private string? cepMsg;
    private HashSet<int> empresasSelecionadas = new();
    private string? empresaMsg;

    protected override async Task OnInitializedAsync() => await Carregar();

    private async Task Carregar()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        empresas = await db.Empresas.Where(e => e.Ativo).OrderBy(e => e.Nome).ToListAsync();
        clientes = await db.Clientes
            .Include(c => c.Empresa)
            .Include(c => c.ClienteEmpresas).ThenInclude(ce => ce.Empresa)
            .Include(c => c.Acordos)
            .OrderBy(c => c.Nome)
            .ToListAsync();
    }

    private void Novo()
    {
        modelo = new Cliente();
        empresasSelecionadas = new();
        empresaMsg = null;
        cepMsg = null;
        editando = true;
    }

    private void Editar(Cliente c)
    {
        modelo = new Cliente
        {
            Id = c.Id,
            EmpresaId = c.EmpresaId,
            Nome = c.Nome,
            CpfCnpj = c.CpfCnpj,
            Telefone = c.Telefone,
            Email = c.Email,
            Cep = c.Cep,
            Logradouro = c.Logradouro,
            Numero = c.Numero,
            Complemento = c.Complemento,
            Bairro = c.Bairro,
            Cidade = c.Cidade,
            Uf = c.Uf,
            Observacoes = c.Observacoes,
            CriadoEm = c.CriadoEm
        };
        empresasSelecionadas = c.ClienteEmpresas.Count > 0
            ? c.ClienteEmpresas.Select(x => x.EmpresaId).ToHashSet()
            : new HashSet<int> { c.EmpresaId };
        empresaMsg = null;
        cepMsg = null;
        editando = true;
    }

    private void Cancelar() => editando = false;

    private void AlternarEmpresa(int empresaId, object? value)
    {
        var marcado = value is bool b && b;
        if (marcado) empresasSelecionadas.Add(empresaId);
        else empresasSelecionadas.Remove(empresaId);
        empresaMsg = null;
    }

    private static string NomesEmpresas(Cliente c)
    {
        var nomes = c.ClienteEmpresas
            .Where(x => x.Empresa is not null)
            .Select(x => x.Empresa!.Nome)
            .Distinct()
            .OrderBy(x => x)
            .ToList();
        return nomes.Count > 0 ? string.Join(", ", nomes) : c.Empresa?.Nome ?? "—";
    }

    private async Task BuscarCep()
    {
        cepMsg = null;
        buscandoCep = true;
        try
        {
            var end = await Endereco.BuscarCepAsync(modelo.Cep);
            if (end is null)
            {
                cepMsg = "CEP não encontrado.";
                return;
            }
            modelo.Logradouro = end.Logradouro;
            modelo.Bairro = end.Bairro;
            modelo.Cidade = end.Cidade;
            modelo.Uf = end.Uf;
        }
        finally
        {
            buscandoCep = false;
        }
    }

    private async Task Salvar()
    {
        if (empresasSelecionadas.Count == 0)
        {
            empresaMsg = "Selecione pelo menos uma empresa.";
            return;
        }

        using var db = await DbFactory.CreateDbContextAsync();
        Cliente entidade;
        if (modelo.Id == 0)
        {
            entidade = modelo;
            entidade.EmpresaId = empresasSelecionadas.OrderBy(x => x).First();
            db.Clientes.Add(entidade);
            await db.SaveChangesAsync();
        }
        else
        {
            entidade = await db.Clientes.FirstAsync(x => x.Id == modelo.Id);
            entidade.EmpresaId = empresasSelecionadas.Contains(modelo.EmpresaId)
                ? modelo.EmpresaId
                : empresasSelecionadas.OrderBy(x => x).First();
            entidade.Nome = modelo.Nome;
            entidade.CpfCnpj = modelo.CpfCnpj;
            entidade.Telefone = modelo.Telefone;
            entidade.Email = modelo.Email;
            entidade.Cep = modelo.Cep;
            entidade.Logradouro = modelo.Logradouro;
            entidade.Numero = modelo.Numero;
            entidade.Complemento = modelo.Complemento;
            entidade.Bairro = modelo.Bairro;
            entidade.Cidade = modelo.Cidade;
            entidade.Uf = modelo.Uf;
            entidade.Observacoes = modelo.Observacoes;
            await db.ClienteEmpresas.Where(x => x.ClienteId == entidade.Id).ExecuteDeleteAsync();
        }

        foreach (var empresaId in empresasSelecionadas)
            db.ClienteEmpresas.Add(new ClienteEmpresa { ClienteId = entidade.Id, EmpresaId = empresaId });

        await db.SaveChangesAsync();
        editando = false;
        await Carregar();
    }

    private async Task Excluir(Cliente c)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Excluir o cliente \"{c.Nome}\" e todos os seus acordos/parcelas?"))
            return;

        using var db = await DbFactory.CreateDbContextAsync();
        db.Clientes.Remove(new Cliente { Id = c.Id });
        await db.SaveChangesAsync();
        await Carregar();
    }
}

<style>
.empresa-multi-list{max-height:180px;overflow:auto;background:var(--bs-body-bg);}
</style>
