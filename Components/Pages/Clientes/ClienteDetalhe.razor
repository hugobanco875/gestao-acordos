@page "/clientes/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Cliente</PageTitle>

@if (cliente is null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <a href="clientes" class="btn btn-sm btn-link px-0"><i class="bi bi-arrow-left"></i> Voltar para clientes</a>
        <h1 class="h3 mb-1"><i class="bi bi-person"></i> @cliente.Nome</h1>
        <div class="text-muted small">
            <span class="me-3"><i class="bi bi-building"></i> @NomesEmpresas</span>
            @if (!string.IsNullOrWhiteSpace(cliente.CpfCnpj))
            {
                <span class="me-3"><i class="bi bi-person-vcard"></i> @cliente.CpfCnpj</span>
            }
            @if (!string.IsNullOrWhiteSpace(cliente.Telefone))
            {
                <span class="me-3"><i class="bi bi-telephone"></i> @cliente.Telefone</span>
            }
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-2">
        <h2 class="h5 mb-0">Acordos / Processos</h2>
        <a class="btn btn-primary btn-sm" href="clientes/@cliente.Id/acordos/novo"><i class="bi bi-plus-lg"></i> Novo acordo</a>
    </div>

    @if (cliente.Acordos.Count == 0)
    {
        <div class="alert alert-info">Nenhum acordo cadastrado para este cliente. Clique em <strong>Novo acordo</strong>.</div>
    }
    else
    {
        @foreach (var a in cliente.Acordos.OrderByDescending(x => x.CriadoEm))
        {
            var pagas = a.Parcelas.Count(p => p.Paga);
            <div class="card mb-2 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between flex-wrap gap-2">
                        <div>
                            <h3 class="h6 mb-1">
                                @if (!string.IsNullOrWhiteSpace(a.NumeroProcesso))
                                {
                                    <span><i class="bi bi-hash"></i>Processo @a.NumeroProcesso</span>
                                }
                                else
                                {
                                    <span>Acordo #@a.Id</span>
                                }
                            </h3>
                            @if (!string.IsNullOrWhiteSpace(a.Descricao))
                            {
                                <div class="small text-muted">@a.Descricao</div>
                            }
                            <div class="mt-1 d-flex flex-wrap gap-1">
                                <span class="badge bg-primary">Total @a.ValorTotal.ToString("C")</span>
                                @if (a.ValorEntrada > 0) { <span class="badge bg-success">Entrada @a.ValorEntrada.ToString("C")</span> }
                                <span class="badge bg-secondary">@a.Empresa?.Nome</span>
                                <span class="badge @(pagas == a.Parcelas.Count ? "bg-success" : "bg-warning text-dark")">
                                    @pagas/@a.Parcelas.Count parcelas pagas
                                </span>
                                @if (QuantidadeArquivos(a) > 0)
                                {
                                    <span class="badge bg-info text-dark">@QuantidadeArquivos(a) arquivo(s)</span>
                                }
                            </div>
                        </div>
                        <div class="text-nowrap">
                            <a class="btn btn-sm btn-outline-success" href="acordos/@a.Id" title="Ver parcelas"><i class="bi bi-list-check"></i> Parcelas</a>
                            @if (QuantidadeArquivos(a) > 0)
                            {
                                <button class="btn btn-sm btn-outline-info" @onclick="() => AbrirArquivos(a)" title="Ver arquivos"><i class="bi bi-folder2-open"></i> Arquivos</button>
                            }
                            <a class="btn btn-sm btn-outline-primary" href="acordos/@a.Id/editar" title="Editar"><i class="bi bi-pencil"></i></a>
                            <button class="btn btn-sm btn-outline-danger" @onclick="() => ExcluirAcordo(a)" title="Excluir"><i class="bi bi-trash"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}

@if (acordoArquivos is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(15,23,42,.55);backdrop-filter:blur(3px)">
        <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header"><h5 class="modal-title"><i class="bi bi-folder2-open"></i> Arquivos do acordo</h5><button class="btn-close" @onclick="FecharArquivos"></button></div>
                <div class="modal-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var arquivo in arquivosModal)
                        {
                            <div class="list-group-item d-flex align-items-center justify-content-between gap-2 py-3">
                                <div class="min-w-0"><div class="fw-semibold text-truncate">@arquivo.Nome</div><div class="small text-muted">@FormatarTamanho(arquivo.Tamanho)</div></div>
                                <button class="btn btn-sm btn-primary flex-shrink-0" @onclick="() => ExibirArquivo(arquivo)"><i class="bi bi-eye"></i> Exibir</button>
                            </div>
                        }
                    </div>
                </div>
                <div class="modal-footer"><button class="btn btn-secondary" @onclick="FecharArquivos">Fechar</button></div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Cliente? cliente;
    private string NomesEmpresas => cliente is null ? "" : string.Join(", ", cliente.ClienteEmpresas.Where(x => x.Empresa is not null).Select(x => x.Empresa!.Nome).Distinct().OrderBy(x => x));

    protected override async Task OnParametersSetAsync() => await Carregar();

    private async Task Carregar()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        cliente = await db.Clientes
            .Include(c => c.Empresa)
            .Include(c => c.ClienteEmpresas).ThenInclude(ce => ce.Empresa)
            .Include(c => c.Acordos).ThenInclude(a => a.Empresa)
            .Include(c => c.Acordos).ThenInclude(a => a.Parcelas)
            .FirstOrDefaultAsync(c => c.Id == Id);

        contagemAnexos.Clear();
        if (cliente is not null)
        {
            var ids = cliente.Acordos.Select(x => x.Id).ToList();
            if (ids.Count > 0)
            {
                var contagens = await db.AcordoAnexos.AsNoTracking()
                    .Where(x => ids.Contains(x.AcordoId))
                    .GroupBy(x => x.AcordoId)
                    .Select(g => new { AcordoId = g.Key, Quantidade = g.Count() })
                    .ToListAsync();
                foreach (var item in contagens) contagemAnexos[item.AcordoId] = item.Quantidade;
            }
        }
    }

    private Acordo? acordoArquivos;
    private readonly Dictionary<int, int> contagemAnexos = new();
    private List<ArquivoModal> arquivosModal = new();
    private sealed class ArquivoModal { public int Id { get; init; } public string Nome { get; init; } = string.Empty; public long Tamanho { get; init; } public bool Legado { get; init; } }

    private int QuantidadeArquivos(Acordo acordo) => contagemAnexos.GetValueOrDefault(acordo.Id) + (acordo.TemPdf ? 1 : 0);

    private async Task AbrirArquivos(Acordo acordo)
    {
        acordoArquivos = acordo;
        using var db = await DbFactory.CreateDbContextAsync();
        arquivosModal = await db.AcordoAnexos.AsNoTracking()
            .Where(x => x.AcordoId == acordo.Id)
            .OrderByDescending(x => x.EnviadoEm)
            .Select(x => new ArquivoModal { Id = x.Id, Nome = x.NomeArquivo, Tamanho = x.TamanhoBytes })
            .ToListAsync();
        if (acordo.TemPdf)
            arquivosModal.Insert(0, new ArquivoModal { Id = acordo.Id, Nome = acordo.PdfNomeArquivo ?? "acordo.pdf", Legado = true });
    }

    private void FecharArquivos() { acordoArquivos = null; arquivosModal.Clear(); }

    private async Task ExibirArquivo(ArquivoModal arquivo)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        byte[]? conteudo = arquivo.Legado
            ? (await db.AcordosPdf.AsNoTracking().FirstOrDefaultAsync(x => x.AcordoId == arquivo.Id))?.Conteudo
            : (await db.AcordoAnexos.AsNoTracking().FirstOrDefaultAsync(x => x.Id == arquivo.Id))?.Conteudo;
        if (conteudo is null) { await JS.InvokeVoidAsync("alert", "Arquivo não encontrado."); return; }
        await JS.InvokeVoidAsync("appDownload.openPdf", Convert.ToBase64String(conteudo));
    }

    private static string FormatarTamanho(long bytes) => bytes <= 0 ? "Arquivo legado" : bytes < 1024 * 1024 ? $"{bytes / 1024d:N0} KB" : $"{bytes / 1024d / 1024d:N1} MB";

    private async Task ExcluirAcordo(Acordo a)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Excluir este acordo e todas as suas parcelas?"))
            return;

        using var db = await DbFactory.CreateDbContextAsync();
        db.Acordos.Remove(new Acordo { Id = a.Id });
        await db.SaveChangesAsync();
        await Carregar();
    }
}
