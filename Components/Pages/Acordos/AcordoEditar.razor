@page "/clientes/{ClienteId:int}/acordos/novo"
@page "/acordos/{Id:int}/editar"
@attribute [Authorize]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject TemporaryUploadService TemporaryUploads

<PageTitle>Acordo</PageTitle>

@if (carregando)
{
    <p><em>Carregando...</em></p>
}
else if (cliente is null)
{
    <div class="alert alert-danger">Cliente não encontrado.</div>
}
else
{
    <div class="mb-3">
        <a href="clientes/@cliente.Id" class="btn btn-sm btn-link px-0"><i class="bi bi-arrow-left"></i> Voltar</a>
        <h1 class="h3 mb-0">@(IsEdit ? "Editar acordo" : "Novo acordo")</h1>
        <div class="text-muted small"><i class="bi bi-person"></i> @cliente.Nome</div>
    </div>

    <EditForm Model="modelo" OnValidSubmit="Salvar">
        <DataAnnotationsValidator />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Empresa do acordo *</label>
                <InputSelect class="form-select" @bind-Value="modelo.EmpresaId" disabled="@IsEdit">
                    <option value="0">Selecione...</option>
                    @foreach (var e in empresasDoCliente)
                    {
                        <option value="@e.Id">@e.Nome</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => modelo.EmpresaId" />
                @if (empresasDoCliente.Count > 1 && !IsEdit)
                {
                    <div class="form-text">Este cliente está vinculado a mais de uma empresa. Escolha a empresa deste acordo.</div>
                }
            </div>
            <div class="col-md-6">
                <label class="form-label">Número do processo</label>
                <InputText class="form-control" @bind-Value="modelo.NumeroProcesso" placeholder="0000000-00.0000.0.00.0000" data-mask="processo" inputmode="numeric" maxlength="25" autocomplete="off" />
            </div>
            <div class="col-12">
                <label class="form-label">Descrição</label>
                <InputText class="form-control" @bind-Value="modelo.Descricao" />
            </div>

            @if (!IsEdit)
            {
                <div class="col-md-4">
                    <label class="form-label">Valor total do acordo (R$) *</label>
                    <InputNumber class="form-control" step="0.01" @bind-Value="modelo.ValorTotal" />
                    <ValidationMessage For="() => modelo.ValorTotal" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Valor da entrada (R$)</label>
                    <InputNumber class="form-control" step="0.01" @bind-Value="modelo.ValorEntrada" />
                    <div class="form-text">Informe zero quando não houver entrada.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Data da entrada</label>
                    <InputDate class="form-control" @bind-Value="modelo.DataEntrada" disabled="@(modelo.ValorEntrada <= 0)" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Forma de pagamento da entrada</label>
                    <InputSelect class="form-select" @bind-Value="modelo.FormaPagamentoEntrada" disabled="@(modelo.ValorEntrada <= 0)">
                        @foreach (var forma in FormasPagamento.OpcoesRecebimento)
                        {
                            <option value="@forma">@FormasPagamento.RotuloSelecao(forma)</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-8">
                    <label class="form-label">Observação da entrada</label>
                    <InputText class="form-control" @bind-Value="modelo.ObservacaoEntrada" disabled="@(modelo.ValorEntrada <= 0)" placeholder="Ex.: entrada recebida via PIX" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Qtd. de parcelas *</label>
                    <InputNumber class="form-control" @bind-Value="modelo.QuantidadeParcelas" />
                    <ValidationMessage For="() => modelo.QuantidadeParcelas" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Data da 1ª parcela *</label>
                    <InputDate class="form-control" @bind-Value="modelo.DataPrimeiraParcela" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Saldo a parcelar</label>
                    <div class="form-control bg-body-tertiary fw-semibold">@SaldoParcelar.ToString("C")</div>
                </div>
                @if (!string.IsNullOrEmpty(erroFinanceiro))
                {
                    <div class="col-12"><div class="alert alert-danger py-2 mb-0">@erroFinanceiro</div></div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="alert alert-secondary mb-0">
                        <strong>Empresa:</strong> @modelo.Empresa?.Nome &nbsp;|&nbsp;
                        <strong>Valor total:</strong> @modelo.ValorTotal.ToString("C") &nbsp;|&nbsp;
                        <strong>Entrada:</strong> @modelo.ValorEntrada.ToString("C") &nbsp;|&nbsp;
                        <strong>Saldo parcelado:</strong> @modelo.ValorParcelado.ToString("C") &nbsp;|&nbsp;
                        <strong>Parcelas:</strong> @modelo.QuantidadeParcelas
                        <div class="small text-muted mt-1">Para alterar valores, entrada ou quantidade de parcelas, exclua e recrie o acordo para preservar baixas já realizadas.</div>
                    </div>
                </div>
            }

            <div class="col-12">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-1"><label class="form-label mb-0">Arquivos do acordo</label><span class="badge text-bg-primary">IMPORTAÇÃO DIRETA</span></div>
                <InputFile id="agreement-file-input" @key="inputFileKey" class="form-control" OnChange="OnArquivosSelecionados" accept=".pdf,.docx,.jpg,.jpeg,.png,application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/jpeg,image/png" multiple disabled="@processandoArquivos" />
                <div class="form-text">Selecione os arquivos: o envio para o servidor começa automaticamente e o progresso de cada um aparece abaixo. Limite de 10 MB por arquivo.</div>

                @if (uploadsEmAndamento.Count > 0)
                {
                    <div class="border rounded-3 mt-3 overflow-hidden">
                        <div class="px-3 py-2 bg-body-tertiary fw-semibold d-flex justify-content-between">
                            <span><i class="bi bi-cloud-arrow-up me-1"></i> Arquivos selecionados</span>
                            <span>@uploadsConcluidos/@uploadsEmAndamento.Count importado(s)</span>
                        </div>
                        <div class="list-group list-group-flush">
                            @foreach (var upload in uploadsEmAndamento)
                            {
                                <div @key="upload.Id" class="list-group-item">
                                    <div class="d-flex justify-content-between gap-2 mb-1">
                                        <span class="text-truncate">@upload.Nome</span>
                                        <span class="small text-muted flex-shrink-0">@(upload.Concluido ? "100%" : upload.Falhou ? "Falhou" : processandoArquivos ? $"{upload.Progresso}%" : "Aguardando")</span>
                                    </div>
                                    <div class="progress" role="progressbar" aria-valuenow="@upload.Progresso" aria-valuemin="0" aria-valuemax="100" style="height: 8px;">
                                        <div class="progress-bar @(upload.Falhou ? "bg-danger" : upload.Concluido ? "bg-success" : processandoArquivos ? "progress-bar-striped progress-bar-animated" : "bg-secondary")" style="width: @($"{upload.Progresso}%")"></div>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(upload.Erro))
                                    {
                                        <div class="small text-danger mt-1">@upload.Erro</div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }

                @if (!string.IsNullOrWhiteSpace(mensagemArquivos))
                {
                    <div class="alert @(houveFalhaUpload ? "alert-warning" : "alert-success") py-2 mt-2 mb-0"><i class="bi @(houveFalhaUpload ? "bi-exclamation-triangle" : "bi-check-circle") me-1"></i>@mensagemArquivos</div>
                }

                @if (arquivosExistentes.Count > 0 || arquivosSelecionados.Count > 0)
                {
                    <div class="border rounded-3 mt-3 overflow-hidden">
                        <div class="px-3 py-2 bg-body-tertiary fw-semibold"><i class="bi bi-folder2-open"></i> Arquivos anexados (@(arquivosExistentes.Count + arquivosSelecionados.Count))</div>
                        <div class="list-group list-group-flush">
                            @foreach (var arquivo in arquivosExistentes)
                            {
                                <div @key="arquivo.Id" class="list-group-item d-flex align-items-center justify-content-between gap-2">
                                    <div class="min-w-0"><div class="text-truncate fw-medium">@arquivo.NomeArquivo</div><div class="small text-muted">@FormatarTamanho(arquivo.TamanhoBytes)</div></div>
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ExibirArquivoExistente(arquivo.Id)"><i class="bi bi-eye"></i> Exibir</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => BaixarArquivoExistente(arquivo.Id)" title="Baixar arquivo" aria-label="Baixar arquivo"><i class="bi bi-download"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => SolicitarRemocaoArquivoExistente(arquivo)" title="Remover arquivo"><i class="bi bi-trash"></i> Remover</button>
                                    </div>
                                </div>
                            }
                            @foreach (var arquivo in arquivosSelecionados)
                            {
                                <div @key="arquivo.Token" class="list-group-item d-flex align-items-center justify-content-between gap-2">
                                    <div class="min-w-0"><div class="text-truncate fw-medium">@arquivo.Nome</div><div class="small text-success">Importado · @FormatarTamanho(arquivo.TamanhoBytes)</div></div>
                                    <div class="d-flex gap-1 flex-shrink-0">
                                        <button type="button" class="btn btn-sm btn-outline-primary" @onclick="() => ExibirArquivoSelecionado(arquivo)"><i class="bi bi-eye"></i> Exibir</button>
                                        <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => BaixarArquivoSelecionado(arquivo)" title="Baixar arquivo" aria-label="Baixar arquivo"><i class="bi bi-download"></i></button>
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => RemoverArquivoSelecionado(arquivo)"><i class="bi bi-x-lg"></i></button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (!IsEdit && SaldoParcelar > 0 && modelo.QuantidadeParcelas > 0)
        {
            var previa = ParcelaHelper.GerarParcelas(SaldoParcelar, modelo.QuantidadeParcelas, modelo.DataPrimeiraParcela);
            <h2 class="h6 mt-4">Resumo financeiro</h2>
            <div class="row g-2 mb-3" style="max-width:720px">
                <div class="col-4"><div class="border rounded-3 p-3"><div class="small text-muted">Total</div><strong>@modelo.ValorTotal.ToString("C")</strong></div></div>
                <div class="col-4"><div class="border rounded-3 p-3"><div class="small text-muted">Entrada</div><strong class="text-success">@modelo.ValorEntrada.ToString("C")</strong></div></div>
                <div class="col-4"><div class="border rounded-3 p-3"><div class="small text-muted">Parcelado</div><strong>@SaldoParcelar.ToString("C")</strong></div></div>
            </div>
            <h2 class="h6">Prévia das parcelas</h2>
            <div class="table-responsive">
                <table class="table table-sm table-bordered" style="max-width:520px">
                    <thead><tr><th>#</th><th>Vencimento</th><th class="text-end">Valor</th></tr></thead>
                    <tbody>
                        @foreach (var p in previa)
                        {
                            <tr><td>@p.Numero</td><td>@p.DataVencimento.ToString("dd/MM/yyyy")</td><td class="text-end">@p.Valor.ToString("C")</td></tr>
                        }
                    </tbody>
                    <tfoot><tr><th colspan="2">Total parcelado</th><th class="text-end">@previa.Sum(x => x.Valor).ToString("C")</th></tr></tfoot>
                </table>
            </div>
        }

        <div class="mt-3">
            <button type="submit" class="btn btn-primary" disabled="@(salvando || processandoArquivos || TemArquivosAguardandoImportacao)"><i class="bi bi-check-lg"></i> @(salvando ? "Salvando..." : processandoArquivos || TemArquivosAguardandoImportacao ? "Enviando arquivos..." : "Salvar acordo")</button>
            <a href="clientes/@cliente.Id" class="btn btn-secondary">Cancelar</a>
        </div>
    </EditForm>
}

@code {
    [Parameter] public int ClienteId { get; set; }
    [Parameter] public int Id { get; set; }

    private bool IsEdit => Id > 0;
    private bool carregando = true;
    private bool salvando;
    private bool processandoArquivos;
    private string? mensagemArquivos;
    private int inputFileKey;
    private bool houveFalhaUpload;
    private DotNetObjectReference<AcordoEditar>? uploadDotNetRef;
    private readonly List<UploadArquivoStatus> uploadsEmAndamento = new();
    private int uploadsConcluidos => uploadsEmAndamento.Count(x => x.Concluido);
    private bool TemArquivosAguardandoImportacao => uploadsEmAndamento.Any(x => !x.Concluido && !x.Falhou);
    private Cliente? cliente;
    private Acordo modelo = new();
    private List<Empresa> empresasDoCliente = new();
    private string? erroFinanceiro;


    private sealed class UploadArquivoStatus
    {
        public string Id { get; } = Guid.NewGuid().ToString("N");
        public string Nome { get; init; } = string.Empty;
        public int Progresso { get; set; }
        public bool Concluido { get; set; }
        public bool Falhou { get; set; }
        public string? Erro { get; set; }
    }

    private sealed class ArquivoSelecionado
    {
        public Guid Token { get; init; }
        public string Nome { get; init; } = string.Empty;
        public string ContentType { get; init; } = "application/octet-stream";
        public long TamanhoBytes { get; init; }
    }

    private sealed class ArquivoExistenteResumo
    {
        public int Id { get; init; }
        public string NomeArquivo { get; init; } = string.Empty;
        public long TamanhoBytes { get; init; }
    }

    private readonly List<ArquivoSelecionado> arquivosSelecionados = new();
    private readonly HashSet<int> arquivosParaRemover = new();
    private List<ArquivoExistenteResumo> arquivosExistentes = new();
    private decimal SaldoParcelar => Math.Max(0, modelo.ValorTotal - modelo.ValorEntrada);

    protected override async Task OnParametersSetAsync()
    {
        carregando = true;
        using var db = await DbFactory.CreateDbContextAsync();
        if (IsEdit)
        {
            modelo = await db.Acordos.Include(a => a.Empresa).FirstOrDefaultAsync(a => a.Id == Id) ?? new Acordo();
            cliente = await db.Clientes
                .Include(c => c.ClienteEmpresas).ThenInclude(ce => ce.Empresa)
                .Include(c => c.Empresa)
                .FirstOrDefaultAsync(c => c.Id == modelo.ClienteId);
        }
        else
        {
            cliente = await db.Clientes
                .Include(c => c.ClienteEmpresas).ThenInclude(ce => ce.Empresa)
                .Include(c => c.Empresa)
                .FirstOrDefaultAsync(c => c.Id == ClienteId);
            modelo = new Acordo { ClienteId = ClienteId };
        }

        if (cliente is not null)
        {
            empresasDoCliente = cliente.ClienteEmpresas
                .Where(x => x.Empresa is not null)
                .Select(x => x.Empresa!)
                .DistinctBy(x => x.Id)
                .OrderBy(x => x.Nome)
                .ToList();
            if (empresasDoCliente.Count == 0 && cliente.Empresa is not null)
                empresasDoCliente.Add(cliente.Empresa);
            if (!IsEdit && empresasDoCliente.Count == 1)
                modelo.EmpresaId = empresasDoCliente[0].Id;
        }
        if (IsEdit)
        {
            arquivosExistentes = await db.AcordoAnexos
                .AsNoTracking()
                .Where(x => x.AcordoId == Id)
                .OrderByDescending(x => x.EnviadoEm)
                .Select(x => new ArquivoExistenteResumo { Id = x.Id, NomeArquivo = x.NomeArquivo, TamanhoBytes = x.TamanhoBytes })
                .ToListAsync();

            // Compatibilidade com acordos antigos que possuíam somente um PDF na tabela legada.
            if (modelo.TemPdf && await db.AcordosPdf.AnyAsync(x => x.AcordoId == Id))
                arquivosExistentes.Insert(0, new ArquivoExistenteResumo { Id = -Id, NomeArquivo = modelo.PdfNomeArquivo ?? "acordo.pdf", TamanhoBytes = 0 });
        }

        carregando = false;
    }

    private static readonly Dictionary<string, string> TiposPermitidos = new(StringComparer.OrdinalIgnoreCase)
    {
        [".pdf"] = "application/pdf",
        [".docx"] = "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
        [".jpg"] = "image/jpeg",
        [".jpeg"] = "image/jpeg",
        [".png"] = "image/png"
    };

    private async Task OnArquivosSelecionados(InputFileChangeEventArgs e)
    {
        if (processandoArquivos)
            return;

        const int maxArquivosPorSelecao = 50;
        var arquivos = e.GetMultipleFiles(maxArquivosPorSelecao);
        if (arquivos.Count == 0)
            return;

        uploadsEmAndamento.Clear();
        uploadsEmAndamento.AddRange(arquivos.Select(f => new UploadArquivoStatus { Nome = f.Name, Progresso = 0 }));
        mensagemArquivos = null;
        houveFalhaUpload = false;

        // O envio começa automaticamente assim que os arquivos são selecionados,
        // sem exigir um clique adicional do usuário.
        await ImportarArquivos();
    }

    private async Task ImportarArquivos()
    {
        if (processandoArquivos || !TemArquivosAguardandoImportacao)
            return;

        processandoArquivos = true;
        mensagemArquivos = null;
        houveFalhaUpload = false;
        uploadDotNetRef?.Dispose();
        uploadDotNetRef = DotNetObjectReference.Create(this);

        var itens = uploadsEmAndamento.Select(x => new { id = x.Id }).ToArray();
        try
        {
            await JS.InvokeVoidAsync("agreementUpload.importFiles", "agreement-file-input", "/api/acordos/upload-temporario", itens, uploadDotNetRef, 4);
        }
        catch (Exception ex)
        {
            processandoArquivos = false;
            houveFalhaUpload = true;
            mensagemArquivos = $"Não foi possível iniciar a importação: {ex.Message}";
        }
    }

    [JSInvokable]
    public Task AtualizarProgressoUpload(string itemId, int progresso)
    {
        var item = uploadsEmAndamento.FirstOrDefault(x => x.Id == itemId);
        if (item is not null && !item.Concluido && !item.Falhou)
            item.Progresso = Math.Clamp(progresso, 0, 99);
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task ConcluirUpload(string itemId, string token, string nome, string contentType, long tamanho)
    {
        var item = uploadsEmAndamento.FirstOrDefault(x => x.Id == itemId);
        if (item is null || !Guid.TryParse(token, out var uploadToken))
            return Task.CompletedTask;

        item.Progresso = 100;
        item.Concluido = true;
        arquivosSelecionados.Add(new ArquivoSelecionado
        {
            Token = uploadToken,
            Nome = nome,
            ContentType = contentType,
            TamanhoBytes = tamanho
        });
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task FalharUpload(string itemId, string erro)
    {
        var item = uploadsEmAndamento.FirstOrDefault(x => x.Id == itemId);
        if (item is not null)
        {
            item.Falhou = true;
            item.Erro = erro;
            item.Progresso = 100;
        }
        houveFalhaUpload = true;
        return InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task FinalizarLoteUpload()
    {
        processandoArquivos = false;
        var importados = uploadsEmAndamento.Count(x => x.Concluido);
        var falhas = uploadsEmAndamento.Count(x => x.Falhou);
        mensagemArquivos = falhas > 0
            ? $"{importados} arquivo(s) importado(s) e {falhas} com falha. Selecione novamente os arquivos que falharam."
            : $"{importados} arquivo(s) importado(s) com sucesso. Agora clique em Salvar acordo.";
        inputFileKey++;
        return InvokeAsync(StateHasChanged);
    }

    private async Task ExibirArquivoExistente(int id)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        byte[]? conteudo;
        if (id < 0)
            conteudo = (await db.AcordosPdf.AsNoTracking().FirstOrDefaultAsync(x => x.AcordoId == -id))?.Conteudo;
        else
            conteudo = (await db.AcordoAnexos.AsNoTracking().FirstOrDefaultAsync(x => x.Id == id))?.Conteudo;

        if (conteudo is null)
        {
            await JS.InvokeVoidAsync("alert", "Arquivo não encontrado.");
            return;
        }
        var nomeArquivo = id < 0 ? "acordo.pdf" : arquivosExistentes.FirstOrDefault(x => x.Id == id)?.NomeArquivo ?? "arquivo";
        var contentType = TipoPeloNome(nomeArquivo);
        await JS.InvokeVoidAsync("appDownload.openFile", nomeArquivo, contentType, Convert.ToBase64String(conteudo));
    }

    private async Task ExibirArquivoSelecionado(ArquivoSelecionado arquivo)
    {
        if (!TemporaryUploads.TryGet(arquivo.Token, out var upload))
        {
            await JS.InvokeVoidAsync("alert", "O arquivo temporário expirou. Importe-o novamente.");
            return;
        }
        await JS.InvokeVoidAsync("appDownload.openFile", arquivo.Nome, arquivo.ContentType, Convert.ToBase64String(upload.Content));
    }

    private async Task BaixarArquivoSelecionado(ArquivoSelecionado arquivo)
    {
        if (!TemporaryUploads.TryGet(arquivo.Token, out var upload))
        {
            await JS.InvokeVoidAsync("alert", "O arquivo temporário expirou. Importe-o novamente.");
            return;
        }
        await JS.InvokeVoidAsync("appDownload.fromBytes", arquivo.Nome, arquivo.ContentType, Convert.ToBase64String(upload.Content));
    }

    private async Task BaixarArquivoExistente(int id)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        byte[]? conteudo = id < 0
            ? (await db.AcordosPdf.AsNoTracking().FirstOrDefaultAsync(x => x.AcordoId == -id))?.Conteudo
            : (await db.AcordoAnexos.AsNoTracking().FirstOrDefaultAsync(x => x.Id == id))?.Conteudo;
        if (conteudo is null) { await JS.InvokeVoidAsync("alert", "Arquivo não encontrado."); return; }
        var nomeArquivo = id < 0 ? (arquivosExistentes.FirstOrDefault(x => x.Id == id)?.NomeArquivo ?? "acordo.pdf") : arquivosExistentes.FirstOrDefault(x => x.Id == id)?.NomeArquivo ?? "arquivo";
        await JS.InvokeVoidAsync("appDownload.fromBytes", nomeArquivo, TipoPeloNome(nomeArquivo), Convert.ToBase64String(conteudo));
    }

    private void RemoverArquivoSelecionado(ArquivoSelecionado arquivo)
    {
        TemporaryUploads.Remove(arquivo.Token);
        arquivosSelecionados.Remove(arquivo);
    }

    private async Task SolicitarRemocaoArquivoExistente(ArquivoExistenteResumo arquivo)
    {
        var confirmar = await JS.InvokeAsync<bool>("confirm", $"Deseja remover somente o arquivo '{arquivo.NomeArquivo}'? A remoção será concluída ao salvar o acordo.");
        if (!confirmar)
            return;

        arquivosParaRemover.Add(arquivo.Id);
        arquivosExistentes.Remove(arquivo);
    }

    private static string TipoPeloNome(string nomeArquivo)
    {
        var extensao = Path.GetExtension(nomeArquivo);
        return TiposPermitidos.TryGetValue(extensao, out var tipo) ? tipo : "application/octet-stream";
    }

    private static string FormatarTamanho(long bytes)
        => bytes <= 0 ? "Arquivo legado" : bytes < 1024 * 1024 ? $"{bytes / 1024d:N0} KB" : $"{bytes / 1024d / 1024d:N1} MB";

    private async Task Salvar()
    {
        erroFinanceiro = null;
        if (!IsEdit)
        {
            if (modelo.ValorEntrada < 0 || modelo.ValorEntrada >= modelo.ValorTotal)
            {
                erroFinanceiro = "O valor da entrada deve ser menor que o valor total do acordo.";
                return;
            }
            if (modelo.ValorEntrada > 0 && modelo.DataEntrada is null)
                modelo.DataEntrada = GestaoAcordos.Services.RelogioSistema.Hoje;
            if (modelo.ValorEntrada == 0)
                modelo.DataEntrada = null;
            if (!empresasDoCliente.Any(x => x.Id == modelo.EmpresaId))
            {
                erroFinanceiro = "Selecione uma empresa vinculada ao cliente.";
                return;
            }
        }

        if (processandoArquivos || TemArquivosAguardandoImportacao)
            return;

        salvando = true;
        try
        {
            var uploadsProntos = new Dictionary<Guid, TemporaryUpload>();
            foreach (var arquivo in arquivosSelecionados)
            {
                if (!TemporaryUploads.TryGet(arquivo.Token, out var upload))
                    throw new InvalidOperationException($"O arquivo '{arquivo.Nome}' expirou antes do salvamento. Importe-o novamente.");
                uploadsProntos[arquivo.Token] = upload;
            }

            await using var db = await DbFactory.CreateDbContextAsync();
            await using var tx = await db.Database.BeginTransactionAsync();

            if (IsEdit)
            {
                var acordo = await db.Acordos.FirstOrDefaultAsync(a => a.Id == Id);
                if (acordo is null) return;

                acordo.NumeroProcesso = modelo.NumeroProcesso;
                acordo.Descricao = modelo.Descricao;
                await RemoverAnexosMarcados(db, acordo);

                var quantidadeAntes = await db.AcordoAnexos.CountAsync(x => x.AcordoId == acordo.Id);
                foreach (var arquivo in arquivosSelecionados)
                    db.AcordoAnexos.Add(CriarAnexo(acordo.Id, arquivo, uploadsProntos[arquivo.Token]));

                await db.SaveChangesAsync();
                var quantidadeDepois = await db.AcordoAnexos.CountAsync(x => x.AcordoId == acordo.Id);
                if (quantidadeDepois != quantidadeAntes + arquivosSelecionados.Count - arquivosParaRemover.Count(x => x > 0))
                    throw new InvalidOperationException("Nem todos os anexos foram confirmados no banco de dados.");
            }
            else
            {
                modelo.CriadoEm = GestaoAcordos.Services.RelogioSistema.Agora;
                modelo.Parcelas = ParcelaHelper.GerarParcelas(SaldoParcelar, modelo.QuantidadeParcelas, modelo.DataPrimeiraParcela);

                // Os anexos são inseridos explicitamente depois que o acordo recebe
                // seu ID. Isso evita depender do rastreamento do grafo do EF e garante
                // que todos os arquivos selecionados sejam persistidos no primeiro salvar.
                modelo.Anexos = new List<AcordoAnexo>();

                if (modelo.ValorEntrada > 0)
                {
                    modelo.Parcelas.Add(new Parcela
                    {
                        Tipo = TipoMovimentoFinanceiro.Entrada,
                        Numero = 0,
                        Valor = modelo.ValorEntrada,
                        DataVencimento = modelo.DataEntrada ?? GestaoAcordos.Services.RelogioSistema.Hoje,
                        Paga = true,
                        DataPagamento = modelo.DataEntrada ?? GestaoAcordos.Services.RelogioSistema.Hoje,
                        ValorPago = modelo.ValorEntrada,
                        FormaPagamento = modelo.FormaPagamentoEntrada,
                        Observacao = modelo.ObservacaoEntrada
                    });
                }

                db.Acordos.Add(modelo);
                await db.SaveChangesAsync();

                foreach (var arquivo in arquivosSelecionados)
                    db.AcordoAnexos.Add(CriarAnexo(modelo.Id, arquivo, uploadsProntos[arquivo.Token]));

                if (arquivosSelecionados.Count > 0)
                {
                    await db.SaveChangesAsync();
                    var anexosGravados = await db.AcordoAnexos.CountAsync(x => x.AcordoId == modelo.Id);
                    if (anexosGravados != arquivosSelecionados.Count)
                        throw new InvalidOperationException($"Foram selecionados {arquivosSelecionados.Count} arquivo(s), mas apenas {anexosGravados} foram confirmados no banco de dados.");
                }
            }

            await tx.CommitAsync();
            foreach (var arquivo in arquivosSelecionados)
                TemporaryUploads.Remove(arquivo.Token);
            Nav.NavigateTo($"clientes/{cliente!.Id}");
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Não foi possível salvar o acordo e seus anexos. Nenhuma alteração foi concluída. Detalhes: {ex.Message}");
        }
        finally
        {
            salvando = false;
        }
    }

    private static string NomeForma(FormaPagamento forma) => FormasPagamento.Nome(forma);

    private async Task RemoverAnexosMarcados(ApplicationDbContext db, Acordo acordo)
    {
        foreach (var id in arquivosParaRemover)
        {
            if (id < 0)
            {
                var legado = await db.AcordosPdf.FirstOrDefaultAsync(x => x.AcordoId == -id);
                if (legado is not null)
                    db.AcordosPdf.Remove(legado);

                acordo.PdfNomeArquivo = null;
                acordo.PdfContentType = null;
                continue;
            }

            var anexo = await db.AcordoAnexos.FirstOrDefaultAsync(x => x.Id == id && x.AcordoId == acordo.Id);
            if (anexo is not null)
                db.AcordoAnexos.Remove(anexo);
        }
    }

    private static AcordoAnexo CriarAnexo(int acordoId, ArquivoSelecionado arquivo, TemporaryUpload upload)
        => new()
        {
            AcordoId = acordoId,
            NomeArquivo = arquivo.Nome,
            ContentType = arquivo.ContentType,
            Conteudo = upload.Content,
            TamanhoBytes = upload.Content.LongLength,
            EnviadoEm = GestaoAcordos.Services.RelogioSistema.Agora
        };

    public ValueTask DisposeAsync()
    {
        uploadDotNetRef?.Dispose();
        foreach (var arquivo in arquivosSelecionados)
            TemporaryUploads.Remove(arquivo.Token);
        return ValueTask.CompletedTask;
    }

}
