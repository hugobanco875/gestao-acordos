@page "/acordos/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Parcelas do acordo</PageTitle>

@if (acordo is null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="mb-3">
        <a href="clientes/@acordo.ClienteId" class="btn btn-sm btn-link px-0"><i class="bi bi-arrow-left"></i> Voltar</a>
        <h1 class="h3 mb-1"><i class="bi bi-list-check"></i> Parcelas do acordo</h1>
        <div class="text-muted small">
            <i class="bi bi-person"></i> @acordo.Cliente?.Nome
            @if (!string.IsNullOrWhiteSpace(acordo.NumeroProcesso))
            {
                <span> &nbsp;—&nbsp; Processo @acordo.NumeroProcesso</span>
            }
        </div>
    </div>

    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body py-2"><div class="small text-muted">Valor total</div><div class="fw-bold">@acordo.ValorTotal.ToString("C")</div></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body py-2"><div class="small text-muted">Recebido</div><div class="fw-bold text-success">@Recebido.ToString("C")</div></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body py-2"><div class="small text-muted">Em aberto</div><div class="fw-bold text-danger">@EmAberto.ToString("C")</div></div></div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card text-center h-100"><div class="card-body py-2"><div class="small text-muted">Parcelas pagas</div><div class="fw-bold">@acordo.Parcelas.Count(p => p.Paga)/@acordo.Parcelas.Count</div></div></div>
        </div>
    </div>

    @if (acordo.TemPdf)
    {
        <button class="btn btn-outline-info btn-sm mb-3" @onclick="VerPdf"><i class="bi bi-file-earmark-pdf"></i> Ver PDF do acordo</button>
    }

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Vencimento</th>
                    <th class="text-end">Valor</th>
                    <th>Status</th>
                    <th>Pagamento</th>
                    <th class="text-end">Ação</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var p in acordo.Parcelas.OrderBy(x => x.Numero))
                {
                    <tr class="@LinhaClasse(p)">
                        <td>@p.Numero</td>
                        <td>@p.DataVencimento.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">@p.Valor.ToString("C")</td>
                        <td>
                            @if (p.Paga)
                            {
                                <span class="badge bg-success">Paga</span>
                            }
                            else if (p.DataVencimento < hoje)
                            {
                                <span class="badge bg-danger">Vencida</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">A vencer</span>
                            }
                        </td>
                        <td>
                            @if (p.Paga)
                            {
                                <span>@p.DataPagamento?.ToString("dd/MM/yyyy")</span>
                            }
                            else if (datasBaixa.ContainsKey(p.Id))
                            {
                                <input type="date" class="form-control form-control-sm" style="max-width:160px"
                                       value="@datasBaixa[p.Id].ToString("yyyy-MM-dd")"
                                       @onchange="e => SetDataBaixa(p.Id, e.Value)" />
                            }
                        </td>
                        <td class="text-end text-nowrap">
                            @if (p.Paga)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => Estornar(p)"><i class="bi bi-arrow-counterclockwise"></i> Estornar</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => Baixar(p)"><i class="bi bi-check-lg"></i> Baixar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Acordo? acordo;
    private readonly DateOnly hoje = DateOnly.FromDateTime(DateTime.Today);
    private Dictionary<int, DateOnly> datasBaixa = new();

    private decimal Recebido => acordo?.Parcelas.Where(p => p.Paga).Sum(p => p.ValorPago ?? p.Valor) ?? 0;
    private decimal EmAberto => (acordo?.ValorTotal ?? 0) - Recebido;

    protected override async Task OnParametersSetAsync() => await Carregar();

    private async Task Carregar()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        acordo = await db.Acordos
            .Include(a => a.Cliente)
            .Include(a => a.Parcelas)
            .FirstOrDefaultAsync(a => a.Id == Id);
        datasBaixa = acordo?.Parcelas.Where(p => !p.Paga).ToDictionary(p => p.Id, _ => hoje) ?? new();
    }

    private string LinhaClasse(Parcela p)
    {
        if (p.Paga) return "table-success";
        if (p.DataVencimento < hoje) return "table-warning";
        return "";
    }

    private void SetDataBaixa(int parcelaId, object? valor)
    {
        if (DateOnly.TryParse(valor?.ToString(), System.Globalization.CultureInfo.InvariantCulture, out var d))
            datasBaixa[parcelaId] = d;
    }

    private async Task Baixar(Parcela p)
    {
        var data = datasBaixa.TryGetValue(p.Id, out var d) ? d : hoje;
        using var db = await DbFactory.CreateDbContextAsync();
        var parcela = await db.Parcelas.FirstOrDefaultAsync(x => x.Id == p.Id);
        if (parcela is null) return;
        parcela.Paga = true;
        parcela.DataPagamento = data;
        parcela.ValorPago = parcela.Valor;
        await db.SaveChangesAsync();
        await Carregar();
    }

    private async Task Estornar(Parcela p)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Estornar a baixa desta parcela?"))
            return;

        using var db = await DbFactory.CreateDbContextAsync();
        var parcela = await db.Parcelas.FirstOrDefaultAsync(x => x.Id == p.Id);
        if (parcela is null) return;
        parcela.Paga = false;
        parcela.DataPagamento = null;
        parcela.ValorPago = null;
        await db.SaveChangesAsync();
        await Carregar();
    }

    private async Task VerPdf()
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var pdf = await db.AcordosPdf.FirstOrDefaultAsync(p => p.AcordoId == Id);
        if (pdf is null)
        {
            await JS.InvokeVoidAsync("alert", "PDF não encontrado.");
            return;
        }
        await JS.InvokeVoidAsync("appDownload.openPdf", Convert.ToBase64String(pdf.Conteudo));
    }
}
