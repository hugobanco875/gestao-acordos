@page "/acordos/{Id:int}"
@attribute [Authorize]
@rendermode InteractiveServer
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject IJSRuntime JS

<PageTitle>Financeiro do acordo</PageTitle>

@if (acordo is null)
{
    <p><em>Carregando...</em></p>
}
else
{
    <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
            <a href="clientes/@acordo.ClienteId" class="btn btn-sm btn-link px-0"><i class="bi bi-arrow-left"></i> Voltar</a>
            <h1 class="h3 mb-1"><i class="bi bi-wallet2"></i> Financeiro do acordo</h1>
            <div class="text-muted small">
                <i class="bi bi-person"></i> @acordo.Cliente?.Nome &nbsp;—&nbsp; <i class="bi bi-building"></i> @acordo.Empresa?.Nome
                @if (!string.IsNullOrWhiteSpace(acordo.NumeroProcesso)) { <span> &nbsp;—&nbsp; Processo @acordo.NumeroProcesso</span> }
            </div>
        </div>
        <button class="btn btn-primary" @onclick="AbrirNovaEntrada"><i class="bi bi-plus-lg"></i> Registrar entrada</button>
    </div>

    <div class="row g-2 mb-4">
        <div class="col-6 col-lg"><div class="card text-center h-100"><div class="card-body py-3"><div class="small text-muted">Valor do acordo</div><div class="fw-bold">@acordo.ValorTotal.ToString("C")</div></div></div></div>
        <div class="col-6 col-lg"><div class="card text-center h-100"><div class="card-body py-3"><div class="small text-muted">Entradas recebidas</div><div class="fw-bold text-success">@TotalEntradas.ToString("C")</div></div></div></div>
        <div class="col-6 col-lg"><div class="card text-center h-100"><div class="card-body py-3"><div class="small text-muted">Recebido total</div><div class="fw-bold text-success">@Recebido.ToString("C")</div></div></div></div>
        <div class="col-6 col-lg"><div class="card text-center h-100"><div class="card-body py-3"><div class="small text-muted">Em aberto</div><div class="fw-bold text-danger">@EmAberto.ToString("C")</div></div></div></div>
        <div class="col-6 col-lg"><div class="card text-center h-100"><div class="card-body py-3"><div class="small text-muted">Parcelas pagas</div><div class="fw-bold">@ParcelasPagas/@ParcelasTotais</div></div></div></div>
    </div>

    @if (acordo.TemPdf)
    {
        <button class="btn btn-outline-info btn-sm mb-3" @onclick="VerPdf"><i class="bi bi-file-earmark-pdf"></i> Ver PDF do acordo</button>
    }

    <h2 class="h5 mb-3">Extrato financeiro</h2>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead><tr><th>Movimento</th><th>Data</th><th class="text-end">Valor</th><th>Forma</th><th>Status</th><th>Observação</th><th class="text-end">Ações</th></tr></thead>
            <tbody>
                @foreach (var p in acordo.Parcelas.OrderBy(x => x.DataVencimento).ThenBy(x => x.Tipo).ThenBy(x => x.Numero))
                {
                    <tr class="@LinhaClasse(p)">
                        <td><span class="badge @(p.Tipo == TipoMovimentoFinanceiro.Entrada ? "bg-primary" : "bg-secondary")">@p.DescricaoMovimento</span></td>
                        <td>@p.DataVencimento.ToString("dd/MM/yyyy")</td>
                        <td class="text-end">@p.Valor.ToString("C")</td>
                        <td>@NomeForma(p.FormaPagamento)</td>
                        <td>
                            @if (p.Paga) { <span class="badge bg-success">Recebida @p.DataPagamento?.ToString("dd/MM/yyyy")</span> }
                            else if (p.DataVencimento < hoje) { <span class="badge bg-danger">Vencida</span> }
                            else { <span class="badge bg-secondary">Em aberto</span> }
                        </td>
                        <td>@(string.IsNullOrWhiteSpace(p.Observacao) ? "—" : p.Observacao)</td>
                        <td class="text-end text-nowrap">
                            @if (!string.IsNullOrWhiteSpace(p.ComprovanteNomeArquivo))
                            {
                                <button class="btn btn-sm btn-outline-info" title="Ver comprovante" @onclick="() => VerComprovante(p.Id)"><i class="bi bi-paperclip"></i></button>
                            }
                            @if (p.Paga)
                            {
                                <button class="btn btn-sm btn-outline-secondary" @onclick="() => SolicitarConfirmacao(p, true)"><i class="bi bi-arrow-counterclockwise"></i> Estornar</button>
                            }
                            else
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => SolicitarConfirmacao(p, false)"><i class="bi bi-check-lg"></i> Baixar</button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (novaEntradaAberta)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(15,23,42,.55);backdrop-filter:blur(3px)">
        <div class="modal-dialog modal-dialog-centered"><div class="modal-content border-0 shadow-lg">
            <div class="modal-header"><h5 class="modal-title">Registrar nova entrada</h5><button class="btn-close" @onclick="FecharNovaEntrada"></button></div>
            <div class="modal-body">
                <div class="row g-3">
                    <div class="col-md-6"><label class="form-label">Valor *</label><InputNumber class="form-control" step="0.01" @bind-Value="novaEntradaValor" /></div>
                    <div class="col-md-6"><label class="form-label">Data *</label><InputDate class="form-control" @bind-Value="novaEntradaData" /></div>
                    <div class="col-12"><label class="form-label">Forma de pagamento</label><select class="form-select" @bind="novaEntradaForma">@foreach(var f in FormasPagamento.OpcoesRecebimento){<option value="@f">@FormasPagamento.RotuloSelecao(f)</option>}</select></div>
                    <div class="col-12"><label class="form-label">Observação</label><textarea class="form-control" rows="2" @bind="novaEntradaObservacao"></textarea></div>
                    <div class="col-12"><label class="form-label">Comprovante (PDF, JPG ou PNG)</label><InputFile class="form-control" OnChange="OnComprovanteSelecionado" accept="application/pdf,image/jpeg,image/png,image/webp" />@if(comprovanteBytes is not null){<div class="form-text text-success">@comprovanteNome selecionado</div>}</div>
                    @if(!string.IsNullOrWhiteSpace(erroEntrada)){<div class="col-12"><div class="alert alert-danger mb-0">@erroEntrada</div></div>}
                </div>
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" @onclick="FecharNovaEntrada">Cancelar</button><button class="btn btn-primary" @onclick="SalvarNovaEntrada" disabled="@salvandoEntrada">Salvar entrada</button></div>
        </div></div>
    </div>
}

@if (parcelaConfirmacao is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(15,23,42,.55);backdrop-filter:blur(3px)">
        <div class="modal-dialog modal-dialog-centered"><div class="modal-content border-0 shadow-lg">
            <div class="modal-header"><h5 class="modal-title">@(confirmandoEstorno ? "Confirmar estorno" : "Confirmar baixa")</h5><button class="btn-close" @onclick="CancelarConfirmacao"></button></div>
            <div class="modal-body">
                <p>@(confirmandoEstorno ? "Esta movimentação voltará a ficar em aberto. Deseja continuar?" : "Confirme os dados antes de registrar o recebimento.")</p>
                <div class="rounded-3 bg-body-tertiary p-3 small mb-3"><div><strong>Movimento:</strong> @parcelaConfirmacao.DescricaoMovimento</div><div><strong>Valor:</strong> @parcelaConfirmacao.Valor.ToString("C")</div></div>
                @if (!confirmandoEstorno)
                {
                    <div class="row g-2"><div class="col-md-6"><label class="form-label">Data da baixa</label><InputDate class="form-control" @bind-Value="dataConfirmacao" /></div><div class="col-md-6"><label class="form-label">Forma de pagamento</label><select class="form-select" @bind="formaConfirmacao">@foreach(var f in FormasPagamento.OpcoesRecebimento){<option value="@f">@FormasPagamento.RotuloSelecao(f)</option>}</select></div></div>
                }
            </div>
            <div class="modal-footer"><button class="btn btn-secondary" @onclick="CancelarConfirmacao">Não, cancelar</button><button class="btn @(confirmandoEstorno ? "btn-warning" : "btn-success")" @onclick="ConfirmarAcao">Sim, @(confirmandoEstorno ? "estornar" : "baixar")</button></div>
        </div></div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }
    private Acordo? acordo;
    private readonly DateOnly hoje = DateOnly.FromDateTime(DateTime.Today);
    private decimal TotalEntradas => acordo?.Parcelas.Where(p => p.Tipo == TipoMovimentoFinanceiro.Entrada && p.Paga).Sum(p => p.ValorPago ?? p.Valor) ?? 0;
    private decimal Recebido => acordo?.Parcelas.Where(p => p.Paga).Sum(p => p.ValorPago ?? p.Valor) ?? 0;
    private decimal EmAberto => Math.Max(0, (acordo?.ValorTotal ?? 0) - Recebido);
    private int ParcelasPagas => acordo?.Parcelas.Count(p => p.Tipo == TipoMovimentoFinanceiro.Parcela && p.Paga) ?? 0;
    private int ParcelasTotais => acordo?.Parcelas.Count(p => p.Tipo == TipoMovimentoFinanceiro.Parcela) ?? 0;

    protected override async Task OnParametersSetAsync() => await Carregar();
    private async Task Carregar(){using var db=await DbFactory.CreateDbContextAsync();acordo=await db.Acordos.Include(a=>a.Cliente).Include(a=>a.Empresa).Include(a=>a.Parcelas).FirstOrDefaultAsync(a=>a.Id==Id);}
    private string LinhaClasse(Parcela p)=>p.Paga?"table-success":p.DataVencimento<hoje?"table-warning":"";

    private bool novaEntradaAberta, salvandoEntrada;
    private decimal novaEntradaValor;
    private DateOnly novaEntradaData = DateOnly.FromDateTime(DateTime.Today);
    private FormaPagamento novaEntradaForma = FormaPagamento.Pix;
    private string? novaEntradaObservacao, erroEntrada, comprovanteNome, comprovanteTipo;
    private byte[]? comprovanteBytes;
    private void AbrirNovaEntrada(){novaEntradaAberta=true;novaEntradaValor=0;novaEntradaData=hoje;novaEntradaForma=FormaPagamento.Pix;novaEntradaObservacao=null;erroEntrada=null;comprovanteBytes=null;comprovanteNome=null;}
    private void FecharNovaEntrada()=>novaEntradaAberta=false;
    private async Task OnComprovanteSelecionado(InputFileChangeEventArgs e){const long max=10*1024*1024;var f=e.File;if(f.Size>max){erroEntrada="O comprovante deve ter no máximo 10 MB.";return;}using var ms=new MemoryStream();await f.OpenReadStream(max).CopyToAsync(ms);comprovanteBytes=ms.ToArray();comprovanteNome=f.Name;comprovanteTipo=f.ContentType;}
    private async Task SalvarNovaEntrada(){erroEntrada=null;if(acordo is null||novaEntradaValor<=0){erroEntrada="Informe um valor de entrada maior que zero.";return;}if(Recebido+novaEntradaValor>acordo.ValorTotal){erroEntrada="A entrada ultrapassa o saldo em aberto do acordo.";return;}salvandoEntrada=true;using var db=await DbFactory.CreateDbContextAsync();var p=new Parcela{AcordoId=Id,Tipo=TipoMovimentoFinanceiro.Entrada,Numero=0,Valor=novaEntradaValor,DataVencimento=novaEntradaData,Paga=true,DataPagamento=novaEntradaData,ValorPago=novaEntradaValor,FormaPagamento=novaEntradaForma,Observacao=novaEntradaObservacao,ComprovanteNomeArquivo=comprovanteNome,ComprovanteContentType=comprovanteTipo};db.Parcelas.Add(p);await db.SaveChangesAsync();if(comprovanteBytes is not null){db.ParcelaComprovantes.Add(new ParcelaComprovante{ParcelaId=p.Id,Conteudo=comprovanteBytes});await db.SaveChangesAsync();}salvandoEntrada=false;novaEntradaAberta=false;await Carregar();}

    private Parcela? parcelaConfirmacao; private bool confirmandoEstorno; private DateOnly dataConfirmacao=DateOnly.FromDateTime(DateTime.Today); private FormaPagamento formaConfirmacao=FormaPagamento.Pix;
    private void SolicitarConfirmacao(Parcela p,bool estorno){parcelaConfirmacao=p;confirmandoEstorno=estorno;dataConfirmacao=hoje;formaConfirmacao=p.FormaPagamento==FormaPagamento.NaoInformada?FormaPagamento.Pix:p.FormaPagamento;}
    private void CancelarConfirmacao(){parcelaConfirmacao=null;confirmandoEstorno=false;}
    private async Task ConfirmarAcao(){if(parcelaConfirmacao is null)return;using var db=await DbFactory.CreateDbContextAsync();var p=await db.Parcelas.FirstOrDefaultAsync(x=>x.Id==parcelaConfirmacao.Id);if(p is null){CancelarConfirmacao();return;}if(confirmandoEstorno){p.Paga=false;p.DataPagamento=null;p.ValorPago=null;}else{p.Paga=true;p.DataPagamento=dataConfirmacao;p.ValorPago=p.Valor;p.FormaPagamento=formaConfirmacao;}await db.SaveChangesAsync();CancelarConfirmacao();await Carregar();}
    private async Task VerPdf(){using var db=await DbFactory.CreateDbContextAsync();var pdf=await db.AcordosPdf.FirstOrDefaultAsync(p=>p.AcordoId==Id);if(pdf is null){await JS.InvokeVoidAsync("alert","PDF não encontrado.");return;}await JS.InvokeVoidAsync("appDownload.openPdf",Convert.ToBase64String(pdf.Conteudo));}
    private async Task VerComprovante(int parcelaId){using var db=await DbFactory.CreateDbContextAsync();var p=await db.Parcelas.FirstOrDefaultAsync(x=>x.Id==parcelaId);var arq=await db.ParcelaComprovantes.FirstOrDefaultAsync(x=>x.ParcelaId==parcelaId);if(p is null||arq is null){await JS.InvokeVoidAsync("alert","Comprovante não encontrado.");return;}if((p.ComprovanteContentType??"").Contains("pdf"))await JS.InvokeVoidAsync("appDownload.openPdf",Convert.ToBase64String(arq.Conteudo));else await JS.InvokeVoidAsync("appDownload.fromBytes",p.ComprovanteNomeArquivo??"comprovante",p.ComprovanteContentType??"application/octet-stream",Convert.ToBase64String(arq.Conteudo));}
    private static string NomeForma(FormaPagamento f) => FormasPagamento.Nome(f);
}
