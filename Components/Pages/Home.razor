@page "/"
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory

<PageTitle>Dashboard</PageTitle>

<div class="page-heading dashboard-heading">
    <div>
        <span class="dashboard-eyebrow">VISÃO GERAL</span>
        <h1 class="h3"><i class="bi bi-grid-1x2"></i> Dashboard</h1>
        <p class="page-kicker">Acompanhe recebimentos, vencimentos e compromissos em um só lugar.</p>
    </div>
    <a href="clientes" data-enhance-nav="false" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i> Novo acordo</a>
</div>

@if (carregando)
{
    <div class="row g-3">
        @for (var i = 0; i < 4; i++)
        {
            <div class="col-6 col-lg-3"><div class="skeleton" style="height:140px"></div></div>
        }
    </div>
}
else
{
    @if (vencidas.Count > 0)
    {
        <div class="alert alert-danger d-flex justify-content-between align-items-center">
            <span>
                <i class="bi bi-exclamation-triangle-fill"></i>
                <strong>@vencidas.Count</strong> parcela(s) vencida(s) — total <strong>@vencidas.Sum(p => p.Valor).ToString("C")</strong>
            </span>
            <a href="parcelas" class="btn btn-sm btn-danger">Ver</a>
        </div>
    }

    <h2 class="h5 mt-3"><i class="bi bi-cash-coin"></i> Parcelas a receber</h2>
    <div class="row g-3 mb-4">
        <div class="col-6 col-lg-3">
            <a href="parcelas" class="text-decoration-none">
                <div class="card metric-card metric-primary h-100"><div class="card-body">
                    <div class="metric-top"><span class="metric-icon"><i class="bi bi-calendar2-check"></i></span><span class="metric-label">Hoje</span></div>
                    <div class="metric-value">@SomaAbertas(p => p.DataVencimento == hoje).ToString("C")</div>
                    <div class="metric-meta">@ContaAbertas(p => p.DataVencimento == hoje) parcela(s) em aberto</div>
                </div></div>
            </a>
        </div>
        <div class="col-6 col-lg-3">
            <a href="parcelas" class="text-decoration-none">
                <div class="card metric-card metric-info h-100"><div class="card-body">
                    <div class="metric-top"><span class="metric-icon"><i class="bi bi-calendar-week"></i></span><span class="metric-label">Esta semana</span></div>
                    <div class="metric-value">@SomaAbertas(p => p.DataVencimento >= inicioSemana && p.DataVencimento <= fimSemana).ToString("C")</div>
                    <div class="metric-meta">@ContaAbertas(p => p.DataVencimento >= inicioSemana && p.DataVencimento <= fimSemana) parcela(s)</div>
                </div></div>
            </a>
        </div>
        <div class="col-6 col-lg-3">
            <a href="parcelas" class="text-decoration-none">
                <div class="card metric-card metric-neutral h-100"><div class="card-body">
                    <div class="metric-top"><span class="metric-icon"><i class="bi bi-calendar3"></i></span><span class="metric-label">Este mês</span></div>
                    <div class="metric-value">@SomaAbertas(p => p.DataVencimento >= inicioMes && p.DataVencimento <= fimMes).ToString("C")</div>
                    <div class="metric-meta">@ContaAbertas(p => p.DataVencimento >= inicioMes && p.DataVencimento <= fimMes) parcela(s)</div>
                </div></div>
            </a>
        </div>
        <div class="col-6 col-lg-3">
            <a href="relatorios" class="text-decoration-none">
                <div class="card metric-card metric-success h-100"><div class="card-body">
                    <div class="metric-top"><span class="metric-icon"><i class="bi bi-check2-circle"></i></span><span class="metric-label">Recebido no mês</span></div>
                    <div class="metric-value">@recebidoMes.ToString("C")</div>
                    <div class="metric-meta">Pagamentos em @hoje.ToString("MM/yyyy")</div>
                </div></div>
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-6">
            <h2 class="h5"><i class="bi bi-list-ul"></i> Próximas parcelas</h2>
            @if (proximasParcelas.Count == 0)
            {
                <div class="alert alert-info">Nenhuma parcela em aberto.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-striped align-middle">
                        <thead><tr><th>Cliente</th><th>Vencimento</th><th class="text-end">Valor</th></tr></thead>
                        <tbody>
                            @foreach (var p in proximasParcelas)
                            {
                                <tr class="@(p.DataVencimento < hoje ? "table-warning" : "")">
                                    <td><a href="acordos/@p.AcordoId" data-enhance-nav="false">@p.Acordo?.Cliente?.Nome</a></td>
                                    <td>@p.DataVencimento.ToString("dd/MM/yyyy")</td>
                                    <td class="text-end">@p.Valor.ToString("C")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <div class="col-lg-6">
            <h2 class="h5"><i class="bi bi-calendar-event"></i> Eventos</h2>
            <div class="row g-2 mb-3">
                <div class="col-4">
                    <div class="card text-center h-100"><div class="card-body py-2">
                        <div class="small text-muted">Hoje</div><div class="h5 mb-0">@ContaEventos(d => d == hoje)</div>
                    </div></div>
                </div>
                <div class="col-4">
                    <div class="card text-center h-100"><div class="card-body py-2">
                        <div class="small text-muted">Semana</div><div class="h5 mb-0">@ContaEventos(d => d >= inicioSemana && d <= fimSemana)</div>
                    </div></div>
                </div>
                <div class="col-4">
                    <div class="card text-center h-100"><div class="card-body py-2">
                        <div class="small text-muted">Mês</div><div class="h5 mb-0">@ContaEventos(d => d >= inicioMes && d <= fimMes)</div>
                    </div></div>
                </div>
            </div>

            @if (proximosEventos.Count == 0)
            {
                <div class="alert alert-info">Nenhum evento agendado.</div>
            }
            else
            {
                <ul class="list-group">
                    @foreach (var ev in proximosEventos)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge @TipoCor(ev.Tipo) me-1">@TipoNome(ev.Tipo)</span>
                                @ev.Titulo
                                @if (ev.Cliente is not null)
                                {
                                    <div class="small text-muted"><i class="bi bi-person"></i> @ev.Cliente.Nome</div>
                                }
                            </div>
                            <span class="text-nowrap small">@ev.DataHora.ToString("dd/MM HH:mm")</span>
                        </li>
                    }
                </ul>
                <a href="eventos" class="btn btn-sm btn-link px-0 mt-1">Ver todos os eventos</a>
            }
        </div>
    </div>
}

@code {
    private bool carregando = true;

    private readonly DateOnly hoje = DateOnly.FromDateTime(DateTime.Today);
    private DateOnly inicioSemana, fimSemana, inicioMes, fimMes;

    private List<Parcela> abertas = new();
    private List<Parcela> vencidas = new();
    private List<Parcela> proximasParcelas = new();
    private decimal recebidoMes;
    private List<Evento> eventos = new();
    private List<Evento> proximosEventos = new();

    protected override async Task OnInitializedAsync()
    {
        int diff = (7 + (int)DateTime.Today.DayOfWeek - (int)DayOfWeek.Monday) % 7;
        inicioSemana = hoje.AddDays(-diff);
        fimSemana = inicioSemana.AddDays(6);
        inicioMes = new DateOnly(hoje.Year, hoje.Month, 1);
        fimMes = inicioMes.AddMonths(1).AddDays(-1);

        using var db = await DbFactory.CreateDbContextAsync();

        abertas = await db.Parcelas
            .Include(p => p.Acordo)!.ThenInclude(a => a!.Cliente)
            .Where(p => !p.Paga && p.Tipo == TipoMovimentoFinanceiro.Parcela)
            .ToListAsync();

        vencidas = abertas.Where(p => p.DataVencimento < hoje).OrderBy(p => p.DataVencimento).ToList();
        proximasParcelas = abertas.OrderBy(p => p.DataVencimento).Take(8).ToList();

        recebidoMes = await db.Parcelas
            .Where(p => p.Paga && p.DataPagamento >= inicioMes && p.DataPagamento <= fimMes)
            .SumAsync(p => (decimal?)(p.ValorPago ?? p.Valor)) ?? 0;

        eventos = await db.Eventos
            .Include(e => e.Cliente)
            .Where(e => !e.Concluido)
            .ToListAsync();

        proximosEventos = eventos
            .Where(e => e.DataHora >= DateTime.Today)
            .OrderBy(e => e.DataHora)
            .Take(8)
            .ToList();

        carregando = false;
    }

    private decimal SomaAbertas(Func<Parcela, bool> filtro) => abertas.Where(filtro).Sum(p => p.Valor);
    private int ContaAbertas(Func<Parcela, bool> filtro) => abertas.Count(filtro);

    private int ContaEventos(Func<DateOnly, bool> filtro) =>
        eventos.Count(e => filtro(DateOnly.FromDateTime(e.DataHora)));

    private static string TipoNome(TipoEvento t) => t switch
    {
        TipoEvento.Reuniao => "Reunião",
        TipoEvento.Audiencia => "Audiência",
        _ => "Outro"
    };

    private static string TipoCor(TipoEvento t) => t switch
    {
        TipoEvento.Reuniao => "bg-primary",
        TipoEvento.Audiencia => "bg-danger",
        _ => "bg-secondary"
    };
}

<style>
.dashboard-eyebrow{display:block;color:var(--cor-primaria);font-size:.7rem;font-weight:800;letter-spacing:.12em;margin-bottom:.35rem}.dashboard-heading h1{margin-bottom:0!important}.metric-card{position:relative;min-height:140px}.metric-card:before{content:"";position:absolute;inset:0 0 auto 0;height:3px;background:var(--metric)}.metric-card .card-body{display:flex;flex-direction:column;justify-content:center}.metric-top{display:flex;align-items:center;gap:.55rem;margin-bottom:1rem}.metric-icon{width:34px;height:34px;display:grid;place-items:center;border-radius:11px;background:color-mix(in srgb,var(--metric) 10%,white);color:var(--metric)}.metric-label{font-size:.78rem;font-weight:700;color:var(--text-muted)}.metric-value{font-size:clamp(1.25rem,2vw,1.65rem);font-weight:800;letter-spacing:-.04em;color:var(--text)}.metric-meta{font-size:.74rem;color:var(--text-muted);margin-top:.35rem}.metric-primary{--metric:var(--cor-primaria)}.metric-info{--metric:#2684ff}.metric-neutral{--metric:#7c3aed}.metric-success{--metric:#12a66a}@@media(max-width:767.98px){.dashboard-heading{align-items:flex-start}.dashboard-heading .btn{white-space:nowrap;font-size:.76rem}.metric-card{min-height:128px}.metric-value{font-size:1.15rem}.metric-icon{width:30px;height:30px}}
</style>